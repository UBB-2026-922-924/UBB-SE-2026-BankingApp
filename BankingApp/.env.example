# Docker Compose infrastructure values.
# Recommended: generate with `python scripts/secrets/setup_dev.py`.
# Or copy to `.env` and fill in real values manually.
# Never commit `.env`.

# SQL Server SA password (8+ chars, upper+lower+digit+symbol required)
DB_SA_PASSWORD=YourStrong!Passw0rd

# JWT signing secret — must be at least 32 characters (256 bits for HMAC-SHA256)
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG

# OTP server secret — used for TOTP/SMS code generation
OTP_SECRET=CHANGE_ME_OTP_SECRET
