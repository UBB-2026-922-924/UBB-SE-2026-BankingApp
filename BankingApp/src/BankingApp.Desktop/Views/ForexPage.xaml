<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingApp.Desktop.Views.ForexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:BankingApp.Contracts.Features.BillPayments.Dtos"
    xmlns:converters="using:BankingApp.Desktop.Shared.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    RequestedTheme="Light">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid HorizontalAlignment="Stretch" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and Toggle Button -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE118;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontSize="24" />
                        <TextBlock Text="Currency Exchange" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                    <TextBlock Text="Select currencies, enter an amount, and preview the exchange rate before confirming." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                
                <Button Grid.Column="1" VerticalAlignment="Center" Command="{Binding ToggleHistoryCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE81C;" FontSize="16"/>
                        <TextBlock Text="Exchange History" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Exchange Form Card -->
            <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="24" HorizontalAlignment="Stretch" Margin="0,0,0,24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE8D5;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontSize="18"/>
                        <TextBlock Text="Exchange Details" FontWeight="SemiBold" FontSize="18" />
                    </StackPanel>

                    <!-- From Section -->
                    <ComboBox x:Name="SourceAccountCombo"
                              Header="From Account"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedSourceAccount, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4" Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Iban}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Balance}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Currency}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox x:Name="SourceCurrencyCombo"
                              Header="From Currency"
                              ItemsSource="{Binding AvailableCurrencies}"
                              SelectedItem="{Binding SourceCurrency, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />

                    <TextBox x:Name="AmountInput"
                             Header="Amount"
                             Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="0.00"
                             HorizontalAlignment="Stretch" />

                    <!-- Separator Icon -->
                    <FontIcon Glyph="&#xE74B;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontSize="24" HorizontalAlignment="Center" Margin="0,8" />

                    <!-- To Section -->
                    <ComboBox x:Name="TargetAccountCombo"
                              Header="To Account"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedTargetAccount, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4" Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Iban}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Balance}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Currency}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox x:Name="TargetCurrencyCombo"
                              Header="To Currency"
                              ItemsSource="{Binding AvailableCurrencies}"
                              SelectedItem="{Binding TargetCurrency, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

                    <!-- Action Buttons and Preview Section -->
                    <Button Content="Preview Exchange Rate" Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Command="{Binding LoadPreviewCommand}"
                            Visibility="{Binding IsInitialStep, Converter={StaticResource BoolToVis}}" />

                    <!-- Preview details -->
                    <StackPanel Spacing="8" Visibility="{Binding IsPreviewStep, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Live Rate:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding LiveRate}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Commission:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding Commission}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Target Amount:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding TargetAmount}" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="Confirm Exchange" Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" Command="{Binding ExecuteExchangeCommand}" Margin="0,8,0,0"/>
                        <Button Content="Cancel" HorizontalAlignment="Stretch" Command="{Binding ResetCommand}"/>
                    </StackPanel>

                    <!-- Success Details -->
                    <StackPanel Spacing="8" Visibility="{Binding IsResultStep, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="24"/>
                            <TextBlock Text="Exchange Successful!" FontWeight="Bold" FontSize="18" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Transaction Reference:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding TransactionReference}" FontWeight="SemiBold" />
                        </StackPanel>
                        
                        <Button Content="New Exchange" Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" Command="{Binding ResetCommand}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Error message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                    <ProgressRing IsActive="{Binding IsLoading}" Width="24" Height="24" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Exchange History Section -->
            <StackPanel Grid.Row="2" Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVis}}" Margin="0,24,0,0">
                <TextBlock Text="Exchange History" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                
                <ListView ItemsSource="{Binding TransactionHistory}" MaxHeight="400" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="{Binding SourceCurrency}" FontWeight="SemiBold" Width="50" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE72A;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding TargetCurrency}" FontWeight="SemiBold" Width="50" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="3" Text="{Binding TargetAmount}" TextAlignment="Right" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                
                                <StackPanel Grid.Column="4" Orientation="Vertical" Width="100">
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12">
                                        <Run Text="Rate: " />
                                        <Run Text="{Binding ExchangeRate}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Status}" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
