<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingApp.Desktop.Views.InvestmentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:BankingApp.Desktop.Shared.Converters"
    Background="#F4F6FA"
    mc:Ignorable="d">

    <Page.Resources>
        <utils:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <utils:FilterMatchToBooleanConverter x:Key="FilterMatchToBooleanConverter" />
        <utils:DecimalToCurrencyConverter x:Key="DecimalToCurrencyConverter" />
        <utils:DecimalToGainLossBrushConverter x:Key="GainLossBrushConverter" />
        <utils:DecimalToPercentConverter x:Key="DecimalToPercentConverter" />
        <utils:DecimalToTrendSymbolConverter x:Key="TrendSymbolConverter" />
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1360" Margin="48,32,48,40" HorizontalAlignment="Center" Spacing="28">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Portfolio Overview"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#1A1A2E"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" 
                            Content="Trade Assets" 
                            Command="{Binding OpenTradeDialogCommand}"
                            Style="{StaticResource AccentButtonStyle}" 
                            Padding="16,8"
                            VerticalAlignment="Center"/>
                </Grid>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="24"
                            Background="White"
                            BorderBrush="#D8DEE9"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Portfolio Value" FontSize="14" Foreground="#667085" />
                            <TextBlock Text="{Binding UserPortfolio.TotalValue, Converter={StaticResource DecimalToCurrencyConverter}}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="24"
                            Background="White"
                            BorderBrush="#D8DEE9"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Gain/Loss" FontSize="14" Foreground="#667085" />
                            <TextBlock Text="{Binding UserPortfolio.TotalGainLoss, Converter={StaticResource DecimalToCurrencyConverter}}" FontSize="28" FontWeight="SemiBold" Foreground="{Binding UserPortfolio.TotalGainLoss, Converter={StaticResource GainLossBrushConverter}}" />
                            <TextBlock Text="{Binding UserPortfolio.GainLossPercent, Converter={StaticResource DecimalToPercentConverter}}" FontSize="15" Foreground="{Binding UserPortfolio.TotalGainLoss, Converter={StaticResource GainLossBrushConverter}}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="28"
                        Background="White"
                        BorderBrush="#D8DEE9"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="22">
                        <TextBlock Text="Asset Holdings" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A2E" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ToggleButton Content="All" Command="{Binding SelectFilterCommand}" CommandParameter="All" IsChecked="{Binding ActiveFilterType, Converter={StaticResource FilterMatchToBooleanConverter}, ConverterParameter=All}" />
                                <ToggleButton Content="Stocks" Command="{Binding SelectFilterCommand}" CommandParameter="Stocks" IsChecked="{Binding ActiveFilterType, Converter={StaticResource FilterMatchToBooleanConverter}, ConverterParameter=Stocks}" />
                                <ToggleButton Content="Crypto" Command="{Binding SelectFilterCommand}" CommandParameter="Crypto" IsChecked="{Binding ActiveFilterType, Converter={StaticResource FilterMatchToBooleanConverter}, ConverterParameter=Crypto}" />
                            </StackPanel>
                        </ScrollViewer>

                        <ListView ItemsSource="{Binding DisplayedHoldings}" Visibility="{Binding IsHoldingsVisible, Converter={StaticResource BoolToVisibility}}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="18,20"
                                            Margin="0,0,0,12"
                                            Background="White"
                                            BorderBrush="#EEF2F6"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid ColumnSpacing="28">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="170" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Text="{Binding Ticker}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AssetType}" FontSize="12" Opacity="0.68" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding Quantity}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding AvgPurchasePrice, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding CurrentPrice, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding UnrealizedGainLoss, Converter={StaticResource TrendSymbolConverter}}" Foreground="{Binding UnrealizedGainLoss, Converter={StaticResource GainLossBrushConverter}}" />
                                                <TextBlock Text="{Binding UnrealizedGainLoss, Converter={StaticResource DecimalToCurrencyConverter}}" Foreground="{Binding UnrealizedGainLoss, Converter={StaticResource GainLossBrushConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="No holdings found"
                                   HorizontalAlignment="Center"
                                   Foreground="#667085"
                                   Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <ProgressRing Width="48" Height="48" IsActive="{Binding IsPortfolioLoading}" Visibility="{Binding IsPortfolioLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</Page>
