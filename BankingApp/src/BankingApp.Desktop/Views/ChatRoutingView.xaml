<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingApp.Desktop.Views.ChatRoutingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chat="using:BankingApp.Models.Features.Chat"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Support Chats"
                   FontSize="28"
                   FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Welcome to support chat."
                       FontSize="15"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="WaitTimeText"
                       Text="Estimated wait time: calculating..."
                       Opacity="0.75"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <ComboBox x:Name="IssueCategoryComboBox" Width="260" SelectedIndex="0">
                <x:String>Account</x:String>
                <x:String>Cards</x:String>
                <x:String>Transfers</x:String>
                <x:String>Loans</x:String>
                <x:String>Technical Issue</x:String>
                <x:String>Other</x:String>
            </ComboBox>
            <Button Content="Start New Chat"
                    Click="StartNewChat_Click"/>
        </StackPanel>

        <ListView x:Name="SessionsList"
                  Grid.Row="3"
                  IsItemClickEnabled="True"
                  ItemClick="SessionsList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="chat:ChatSession">
                    <StackPanel Padding="8" Spacing="3">
                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind SessionStatus}" Opacity="0.75"/>
                        <TextBlock Text="{x:Bind LastUpdatedDisplay}" FontSize="12" Opacity="0.6"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>