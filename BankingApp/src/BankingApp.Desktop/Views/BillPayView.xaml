<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="BankingApp.Desktop.Views.BillPayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:billers="using:BankingApp.Contracts.Features.Billers.Dtos"
    xmlns:payments="using:BankingApp.Contracts.Features.BillPayments.Dtos"
    xmlns:dtos="using:BankingApp.Contracts.Features.Billers.Dtos"
    xmlns:converters1="using:BankingApp.Desktop.Shared.Converters"
    Background="#DDE3EE">

    <Page.Resources>
        <converters1:StepToVisibilityConverter x:Key="StepToVisibility" />

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#EEF0F5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="#9CA3AF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="CharacterSpacing" Value="50" />
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="#1A1A2E" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1D55D4" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1848BC" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="White"
                                              FontSize="{TemplateBinding FontSize}"
                                              FontFamily="{TemplateBinding FontFamily}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#F3F4F6" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="#374151"
                                              FontSize="{TemplateBinding FontSize}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="36,32" Spacing="24">

                <!-- Page heading -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Pay a Bill"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#1A1A2E" />
                    <TextBlock Text="Search for a biller, enter details, and confirm your payment."
                               FontSize="14" Foreground="#6B7280" />
                </StackPanel>

                <!-- Error InfoBar -->
                <InfoBar Visibility="{Binding ErrorMessageVisibility, Mode=OneWay}"
                         IsOpen="True"
                         Severity="Error"
                         Title="Something went wrong"
                         Message="{Binding ErrorMessage, Mode=OneWay}" />

                <!-- ══════════════════════════════════════
                     STEP 1 – Select Biller
                ══════════════════════════════════════ -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=1}"
                      ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Saved billers sidebar -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}"
                            Visibility="{Binding SavedBillersVisibility}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Saved Billers"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />
                            <TextBlock Text="Tap to quickly fill the form."
                                       FontSize="12" Foreground="#6B7280" />

                            <ListView x:Name="SavedBillersList"
                                      ItemsSource="{Binding SavedBillers}"
                                      IsItemClickEnabled="True"
                                      ItemClick="SavedBillersList_ItemClick"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,4" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dtos:SavedBillerDto">
                                        <Border Padding="12,10" CornerRadius="8"
                                                Background="#EEF3FF"
                                                BorderBrush="#93C5FD" BorderThickness="1">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#1A1A2E" />
                                                <TextBlock Text="{Binding DisplayCategory}"
                                                           FontSize="11"
                                                           Foreground="#6B7280" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- All billers panel -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Find a Biller"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                            <!-- Search + category row -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>

                                <AutoSuggestBox Grid.Column="0"
                                               x:Name="SearchBox"
                                               PlaceholderText="Search billers…"
                                               Text="{Binding SearchQuery, Mode=TwoWay}"
                                               TextChanged="SearchBox_TextChanged"
                                               QueryIcon="Find"
                                               RequestedTheme="Light">
                                    <AutoSuggestBox.Resources>
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlBackground" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7280" />
                                    </AutoSuggestBox.Resources>
                                </AutoSuggestBox>

                                <ComboBox Grid.Column="1"
                                          x:Name="CategoryCombo"
                                          PlaceholderText="All categories"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding SelectedCategory, Mode=TwoWay}"
                                          SelectionChanged="CategoryCombo_SelectionChanged"
                                          HorizontalAlignment="Stretch"
                                          RequestedTheme="Light">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="ComboBoxForeground" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxBackground" Color="White" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F9FAFB" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForeground" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundPointerOver" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundFocused" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundDisabled" Color="#9CA3AF" />
                                    </ComboBox.Resources>
                                    <ComboBoxItem Content="Utilities" />
                                    <ComboBoxItem Content="Telecom" />
                                    <ComboBoxItem Content="Insurance" />
                                    <ComboBoxItem Content="Rent" />
                                    <ComboBoxItem Content="Government" />
                                    <ComboBoxItem Content="Subscriptions" />
                                    <ComboBoxItem Content="Other" />
                                </ComboBox>
                            </Grid>

                            <!-- Biller list -->
                            <ListView x:Name="BillersList"
                                      ItemsSource="{Binding Billers}"
                                      SelectedItem="{Binding SelectedBiller, Mode=TwoWay}"
                                      IsItemClickEnabled="True"
                                      ItemClick="BillersList_ItemClick"
                                      SelectionMode="Single"
                                      MaxHeight="400">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,4" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dtos:BillerDto">
                                        <Border Padding="14,10" CornerRadius="8"
                                                Background="#F1F3F7"
                                                BorderBrush="#C5CAD5" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="14"
                                                               Foreground="#1A1A2E" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Padding="8,3" CornerRadius="6"
                                                        Background="#BFDBFE">
                                                    <TextBlock Text="{Binding Category}"
                                                               FontSize="11"
                                                               Foreground="#1E3A8A"
                                                               FontFamily="Segoe UI Semibold" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════
                     STEP 2 – Payment Details
                ══════════════════════════════════════ -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=2}"
                      ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Form card -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Enter Bill Details"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                            <!-- Selected biller badge -->
                            <Border Padding="14,10" CornerRadius="8"
                                    Background="#BFDBFE" BorderBrush="#3B82F6" BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Selected biller" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding SelectedBillerName}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="#2563EB" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Biller reference / Account number" Style="{StaticResource InputLabel}" />
                                <TextBox Text="{Binding BillerReference, Mode=TwoWay}"
                                         PlaceholderText="e.g. INV-00123 or your customer number"
                                         RequestedTheme="Light">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlBackground" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7280" />
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Amount" Style="{StaticResource InputLabel}" />
                                <NumberBox x:Name="AmountBox"
                                           Value="{x:Bind ViewModel.AmountAsDouble, Mode=TwoWay}"
                                           Minimum="0"
                                           SmallChange="1"
                                           SpinButtonPlacementMode="Compact"
                                           ValueChanged="AmountBox_ValueChanged"
                                           RequestedTheme="Light">
                                    <NumberBox.Resources>
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827" />
                                        <SolidColorBrush x:Key="TextControlBackground" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6B7280" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7280" />
                                    </NumberBox.Resources>
                                </NumberBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Source account" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding Accounts}"
                                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                          PlaceholderText="Select an account"
                                          HorizontalAlignment="Stretch"
                                          RequestedTheme="Light">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="ComboBoxForeground" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="#111827" />
                                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxBackground" Color="White" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F9FAFB" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForeground" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundPointerOver" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundFocused" Color="#6B7280" />
                                        <SolidColorBrush x:Key="ComboBoxPlaceholderTextForegroundDisabled" Color="#9CA3AF" />
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="payments:AccountDto">
                                            <StackPanel Padding="4,2" Spacing="1">
                                                <TextBlock Text="{Binding AccountName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#1A1A2E" />
                                                <TextBlock FontSize="12" Foreground="#6B7280">
                                                    <Run Text="Card ending " />
                                                    <Run Text="{Binding CardLastFourDigits}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding Currency}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Save this biller for future payments" Style="{StaticResource InputLabel}" />
                                <ToggleSwitch IsOn="{Binding ShouldSaveBiller, Mode=TwoWay}"
                                             OnContent="Yes" OffContent="No">
                                    <ToggleSwitch.Resources>
                                        <SolidColorBrush x:Key="ToggleSwitchContentForeground" Color="#111827" />
                                    </ToggleSwitch.Resources>
                                </ToggleSwitch>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource GhostButton}"
                                        Command="{Binding CancelCommand}" />
                                <Button Content="Next →" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding NextStepCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Info sidebar -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <TextBlock Text="How it works"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#2563EB">
                                        <TextBlock Text="1" FontSize="12" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Enter your biller reference"
                                               FontSize="13" Foreground="#374151"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#2563EB">
                                        <TextBlock Text="2" FontSize="12" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Choose the amount and account"
                                               FontSize="13" Foreground="#374151"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#2563EB">
                                        <TextBlock Text="3" FontSize="12" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Review and confirm"
                                               FontSize="13" Foreground="#374151"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#9CA3AF" />

                            <TextBlock Text="A small processing fee may apply. The exact fee will be shown on the review screen."
                                       FontSize="12" Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════
                     STEP 3 – Review and Confirm
                ══════════════════════════════════════ -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=3}"
                      ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Review Payment"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1A1A2E" />

                            <!-- Details grid -->
                            <StackPanel Spacing="0">
                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Biller"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedBillerName}"
                                               Style="{StaticResource ValueText}" />
                                </Grid>
                                <Border Height="1" Background="#CBD5E0" />

                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Reference"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding BillerReference}"
                                               Style="{StaticResource ValueText}" />
                                </Grid>
                                <Border Height="1" Background="#CBD5E0" />

                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="From account"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock Text="{Binding SelectedAccount.AccountName}"
                                                   Style="{StaticResource ValueText}" />
                                        <TextBlock FontSize="12" Foreground="#6B7280">
                                            <Run Text="Card ending " />
                                            <Run Text="{Binding SelectedAccount.CardLastFourDigits}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <Border Height="1" Background="#CBD5E0" />

                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Amount"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ReviewAmountText}"
                                               Style="{StaticResource ValueText}" />
                                </Grid>
                                <Border Height="1" Background="#CBD5E0" />

                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Processing fee"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ReviewFeeText}"
                                               FontSize="14" Foreground="#6B7280" />
                                </Grid>
                                <Border Height="2" Background="#6B7280" />

                                <Grid Padding="0,14" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total debited"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#1A1A2E"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalText}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#2563EB" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="← Back" Style="{StaticResource GhostButton}"
                                        Command="{Binding BackCommand}" />
                                <Button Content="Confirm Payment" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding PayBillCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Note card -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="#2563EB" />
                                <TextBlock Text="Before you confirm"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#1A1A2E"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Please make sure your biller reference is correct. Payments cannot be reversed once submitted."
                                       FontSize="12" Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════
                     STEP 4 – Payment Result
                ══════════════════════════════════════ -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=4}">
                    <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Center">

                        <!-- Success header -->
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="#DCFCE7" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE73E;" FontSize="28" Foreground="#16A34A"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Payment Successful"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#1A1A2E"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ReceiptNumber}"
                                       FontSize="13" Foreground="#6B7280"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Receipt summary -->
                        <Border Padding="20" CornerRadius="10"
                                Background="#F0F4FB" BorderBrush="#9CA3AF" BorderThickness="1">
                            <StackPanel Spacing="0">
                                <Grid Padding="0,10" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Biller"
                                               Style="{StaticResource SectionLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedBillerName}"
                                               Style="{StaticResource ValueText}" />
                                </Grid>
                                <Border Height="1" Background="#9CA3AF" />

                                <Grid Padding="0,10" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Amount"
                                               Style="{StaticResource SectionLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ReviewAmountText}"
                                               Style="{StaticResource ValueText}" />
                                </Grid>

                                <Grid Padding="0,10" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fee"
                                               Style="{StaticResource SectionLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ReviewFeeText}"
                                               FontSize="14" Foreground="#6B7280" />
                                </Grid>
                                <Border Height="2" Background="#6B7280" />

                                <Grid Padding="0,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total debited"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#1A1A2E" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalText}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#2563EB" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button Content="Pay Another Bill" Style="{StaticResource GhostButton}"
                                    Command="{Binding PayAnotherBillCommand}" />
                            <Button Content="Done" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding CancelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

