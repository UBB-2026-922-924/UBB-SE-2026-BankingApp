<Page
    x:Class="BankingApp.Desktop.Views.TransferHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BankingApp.Desktop.Shared.Converters"
    xmlns:vm="using:BankingApp.Desktop.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Transfer History"
                       FontSize="24" FontWeight="Bold"
                       VerticalAlignment="Center" HorizontalAlignment="Left" />
            <Button Content="Refresh"
                    Click="RefreshButton_Click"
                    VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Error InfoBar -->
        <InfoBar Grid.Row="1"
                 IsOpen="{Binding HasError, Mode=OneWay}"
                 Severity="Error"
                 Message="{Binding ErrorMessage, Mode=OneWay}"
                 Margin="0,0,0,12" />

        <!-- Loading indicator -->
        <ProgressRing Grid.Row="2"
                      IsActive="{Binding IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      Margin="0,8,0,16" />

        <!-- Empty-state placeholder -->
        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="{Binding HasNoTransfers, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <FontIcon Glyph="&#xE81C;" FontSize="48" Foreground="#BDBDBD" />
            <TextBlock Text="No transfers yet"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="#9E9E9E"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Your completed transfers will appear here."
                       FontSize="14" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Transfer list -->
        <ListView Grid.Row="3"
                  ItemsSource="{Binding Transfers, Mode=OneWay}"
                  Visibility="{Binding ShowTransferList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                  SelectionMode="None">
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="16,12" Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Recipient" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="Recipient IBAN" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Reference" FontWeight="Bold" />
                        <TextBlock Grid.Column="4" Text="Amount" FontWeight="Bold" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="5" Text="Currency" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="Status" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,0,0,0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16,12" Margin="0,3"
                            Background="White"
                            BorderBrush="#E8ECF0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding DateDisplay}" Foreground="#555" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding RecipientName}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding RecipientIban}" FontFamily="Consolas" Foreground="#666" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding ReferenceDisplay}" Foreground="#999" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" Text="{Binding Amount}" FontWeight="SemiBold" Foreground="#C62828" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            
                            <Border Grid.Column="5" Background="#F0F0F0" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Currency}" Foreground="#333" FontSize="12" />
                            </Border>

                            <Border Grid.Column="6" Background="#E0E0E0" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusDisplay}" Foreground="#333" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

