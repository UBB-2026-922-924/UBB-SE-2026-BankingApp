<Page
    x:Class="BankingApp.Desktop.Views.LoansAndSavingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:BankingApp.Desktop.Views">

    <Grid>
        <TabView IsAddTabButtonVisible="False" CanDragTabs="False">

            <TabViewItem Header="Savings">
                <views:SavingsView DataContext="{Binding SavingsVM}" />
            </TabViewItem>

            <TabViewItem Header="Loans">
                <views:LoansView DataContext="{Binding LoansVM}" />
            </TabViewItem>

        </TabView>
    </Grid>
</Page>