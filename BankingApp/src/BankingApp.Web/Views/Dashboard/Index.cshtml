@model BankingApp.Web.Models.Dashboard.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

@* ── Error alert ─────────────────────────────────────────────────────── *@
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert flash-message alert-danger d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span>@errorMsg</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-danger ms-auto">
            <i class="bi bi-arrow-clockwise me-1"></i>Retry
        </a>
    </div>
}

@* ── Welcome header ───────────────────────────────────────────────────── *@
<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
    <div>
        <p class="text-muted mb-0 small">Welcome back,</p>
        <h1 class="page-title">@Model.UserSummary.FullName</h1>
        @if (!string.IsNullOrWhiteSpace(Model.UserSummary.Email))
        {
            <p class="page-subtitle mb-0">@Model.UserSummary.Email</p>
        }
    </div>
    @if (Model.UnreadNotificationCount > 0)
    {
        <span class="badge rounded-pill bg-danger fs-6 align-self-center">
            <i class="bi bi-bell-fill me-1"></i>@Model.UnreadNotificationCount unread
        </span>
    }
</div>

@* ── Card section ─────────────────────────────────────────────────────── *@
<section class="mb-4">
    <h2 class="h6 text-muted fw-semibold mb-3">Card Details</h2>

    @if (!Model.HasCards)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-credit-card fs-1 text-muted"></i>
                <h5 class="mt-3 text-muted">No cards available</h5>
                <p class="text-muted mb-4">Your linked cards will appear here once they are available.</p>
                <a asp-action="Index" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-arrow-clockwise me-1"></i>Retry
                </a>
            </div>
        </div>
    }
    else
    {
        @* Carousel wrapper *@
        <div class="dash-carousel position-relative">

            @* Prev button *@
            <button id="dash-prev-btn" type="button"
                    class="dash-carousel-btn dash-carousel-btn--prev"
                    aria-label="Previous card">
                <i class="bi bi-chevron-left"></i>
            </button>

            @* Card slides *@
            @for (var i = 0; i < Model.Cards.Count; i++)
            {
                var card = Model.Cards[i];
                <div class="dash-card-slide @(i == 0 ? "dash-card-slide--active" : string.Empty)"
                     data-card-index="@i">
                    <div class="dash-card-widget"
                         data-bs-toggle="collapse"
                         data-bs-target="#card-details-@i"
                         aria-expanded="false"
                         aria-controls="card-details-@i"
                         role="button"
                         title="Click to see card details">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="dash-card-bank fw-bold">BankingApp</span>
                            <span class="dash-card-brand">@card.BrandDisplay</span>
                        </div>
                        <div class="dash-card-contactless">
                            <i class="bi bi-wifi fs-4 opacity-50"></i>
                        </div>
                        <div class="dash-card-number font-monospace fw-semibold mb-3">
                            @card.MaskedNumber
                        </div>
                        <div class="d-flex justify-content-between align-items-end">
                            <div>
                                <div class="dash-card-label">CARD HOLDER</div>
                                <div class="dash-card-value">@card.CardholderDisplay</div>
                            </div>
                            <div class="text-end">
                                <div class="dash-card-label">VALID THRU</div>
                                <div class="dash-card-value">@card.ExpiryDisplay</div>
                            </div>
                        </div>
                    </div>

                    @* Collapsible detail panel — mirrors Desktop card-detail popup *@
                    <div class="collapse" id="card-details-@i">
                        <div class="card border-0 shadow-sm mt-2">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="bi bi-info-circle me-1 text-primary"></i>Card Details
                                </h6>
                                <pre class="mb-2 small text-muted" style="white-space: pre-wrap;">@card.Details</pre>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge rounded-pill bg-light text-secondary border fw-normal">
                                        @if (card.IsContactlessEnabled)
                                        {
                                            <i class="bi bi-check-circle-fill text-success me-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle text-muted me-1"></i>
                                        }
                                        Contactless
                                    </span>
                                    <span class="badge rounded-pill bg-light text-secondary border fw-normal">
                                        @if (card.IsOnlineEnabled)
                                        {
                                            <i class="bi bi-check-circle-fill text-success me-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle text-muted me-1"></i>
                                        }
                                        Online
                                    </span>
                                    <span class="badge @card.StatusBadgeClass">@card.Status</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Next button *@
            <button id="dash-next-btn" type="button"
                    class="dash-carousel-btn dash-carousel-btn--next"
                    aria-label="Next card">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>

        @* Dot indicators (only shown when there is more than 1 card) *@
        @if (Model.Cards.Count > 1)
        {
            <div id="dash-dots" class="dash-card-dots mt-3" aria-hidden="true">
                @for (var i = 0; i < Model.Cards.Count; i++)
                {
                    <span class="dash-dot @(i == 0 ? "dash-dot--active" : string.Empty)"
                          data-dot-index="@i"></span>
                }
            </div>
        }
    }
</section>

@* ── Quick Actions ────────────────────────────────────────────────────── *@
<section class="mb-4">
    <h2 class="h6 text-muted fw-semibold mb-3">Quick Actions</h2>
    <div class="dash-quick-actions">
        <a asp-controller="Transfers" asp-action="New" class="dash-quick-action text-decoration-none">
            <i class="bi bi-arrow-left-right dash-quick-action__icon"></i>
            <span class="dash-quick-action__label">Transfer</span>
        </a>
        <a asp-controller="BillPayments" asp-action="Index" class="dash-quick-action text-decoration-none">
            <i class="bi bi-receipt dash-quick-action__icon"></i>
            <span class="dash-quick-action__label">Pay Bill</span>
        </a>
        <a asp-controller="Forex" asp-action="Index" class="dash-quick-action text-decoration-none">
            <i class="bi bi-currency-exchange dash-quick-action__icon"></i>
            <span class="dash-quick-action__label">Exchange</span>
        </a>
        <a asp-controller="Transfers" asp-action="History" class="dash-quick-action text-decoration-none">
            <i class="bi bi-clock-history dash-quick-action__icon"></i>
            <span class="dash-quick-action__label">History</span>
        </a>
    </div>
</section>

@* ── Recent Transactions ──────────────────────────────────────────────── *@
<section class="mb-4">
    <h2 class="h6 text-muted fw-semibold mb-3">Recent Transactions</h2>

    <div class="card border-0 shadow-sm">
        @if (!Model.HasTransactions)
        {
            <div class="card-body text-center py-4">
                <i class="bi bi-receipt fs-2 text-muted mb-2 d-block"></i>
                <p class="text-muted mb-0">No recent transactions to show.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Merchant</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-end">Amount</th>
                            <th>Currency</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var txn in Model.RecentTransactions)
                        {
                            <tr>
                                <td class="fw-medium">@txn.MerchantDisplay</td>
                                <td class="text-muted small">@txn.Date</td>
                                <td>
                                    <span class="badge @txn.StatusBadgeClass">@txn.StatusDisplay</span>
                                </td>
                                <td class="text-end fw-semibold @(txn.IsCredit ? "amount-credit" : "amount-debit")">
                                    @txn.AmountDisplay
                                </td>
                                <td class="text-muted small">@txn.Currency</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            'use strict';

            // ── Card carousel ─────────────────────────────────────────────────
            var slides = Array.from(document.querySelectorAll('.dash-card-slide'));
            var dots   = Array.from(document.querySelectorAll('.dash-dot'));
            var prevBtn = document.getElementById('dash-prev-btn');
            var nextBtn = document.getElementById('dash-next-btn');

            if (slides.length <= 1) {
                if (prevBtn) prevBtn.style.display = 'none';
                if (nextBtn) nextBtn.style.display = 'none';
                return;
            }

            var current = 0;

            function showSlide(index) {
                slides.forEach(function (s, i) {
                    s.classList.toggle('dash-card-slide--active', i === index);
                });
                dots.forEach(function (d, i) {
                    d.classList.toggle('dash-dot--active', i === index);
                });
                if (prevBtn) prevBtn.disabled = index === 0;
                if (nextBtn) nextBtn.disabled = index === slides.length - 1;
            }

            if (prevBtn) {
                prevBtn.addEventListener('click', function () {
                    if (current > 0) { current--; showSlide(current); }
                });
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', function () {
                    if (current < slides.length - 1) { current++; showSlide(current); }
                });
            }

            // Initialise button states
            showSlide(current);
        })();
    </script>
}
