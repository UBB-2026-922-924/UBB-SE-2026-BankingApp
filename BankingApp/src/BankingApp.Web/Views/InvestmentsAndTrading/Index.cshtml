@model BankingApp.Web.Models.Investments.InvestmentsPageViewModel

@{
    ViewData["Title"] = "Investments Portfolio";
    var portfolio = Model.Portfolio;
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Investments & Trading</h1>
        <p class="page-subtitle">Monitor asset allocations, evaluate net returns, and submit live exchange executions.</p>
    </div>
    <a asp-action="Trade" class="btn btn-primary btn-sm">
        <i class="bi bi-arrow-left-right me-1"></i>Trade Assets
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title text-uppercase text-muted small fw-bold">Portfolio Metric Valuation</h5>
                <div class="my-3">
                    <div class="small text-muted">Total Portfolio Value</div>
                    <h3 class="fw-bold">@portfolio.TotalValue.ToString("N2") RON</h3>
                </div>
                <hr />
                <div>
                    <div class="small text-muted">Total Profit / Loss</div>
                    @{
                        var glClass = portfolio.TotalGainLoss >= 0 ? "text-success" : "text-danger";
                        var glSign = portfolio.TotalGainLoss >= 0 ? "+" : "";
                    }
                    <h4 class="fw-bold @glClass">@glSign@portfolio.TotalGainLoss.ToString("N2") RON</h4>
                    <span class="small fw-semibold @glClass">(@((portfolio.GainLossPercent * 100).ToString("N2"))%)</span>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Filter Holdings</h5>
                <div class="list-group" id="filterButtonGroup">
                    <button type="button" class="list-group-item list-group-item-action filter-item active" data-filter="All">All Asset Classes</button>
                    <button type="button" class="list-group-item list-group-item-action filter-item" data-filter="Stock">Equities / Stocks</button>
                    <button type="button" class="list-group-item list-group-item-action filter-item" data-filter="Crypto">Cryptocurrencies</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted fw-semibold mb-3">Asset Positions</h6>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="webHoldingsTable">
                        <thead class="table-light">
                            <tr class="small text-muted text-uppercase">
                                <th>Asset Ticker</th>
                                <th>Classification</th>
                                <th class="text-end">Owned Quantity</th>
                                <th class="text-end">Avg Position Cost</th>
                                <th class="text-end">Live Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (portfolio.Holdings != null && portfolio.Holdings.Any())
                            {
                                foreach (var holding in portfolio.Holdings)
                                {
                                    <tr class="holding-row-item" data-type="@holding.AssetType">
                                        <td><span class="fw-bold text-dark">@holding.Ticker</span></td>
                                        <td><span class="badge bg-light text-secondary border">@holding.AssetType</span></td>
                                        <td class="text-end font-monospace fw-semibold">@holding.Quantity.ToString("N4")</td>
                                        <td class="text-end font-monospace text-muted">@holding.AvgPurchasePrice.ToString("N2") RON</td>
                                        <td class="text-end font-monospace text-dark fw-semibold">@holding.CurrentPrice.ToString("N2") RON</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr id="emptyRowState">
                                    <td colspan="5" class="text-center text-muted py-4">No active holding asset positions found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.filter-item').click(function () {
                $('.filter-item').removeClass('active');
                $(this).addClass('active');

                var selectedAssetFilter = $(this).data('filter');

                if (selectedAssetFilter === 'All') {
                    $('.holding-row-item').show();
                } else {
                    $('.holding-row-item').hide();
                    $('.holding-row-item[data-type="' + selectedAssetFilter + '"]').show();
                }
            });
        });
    </script>
}
