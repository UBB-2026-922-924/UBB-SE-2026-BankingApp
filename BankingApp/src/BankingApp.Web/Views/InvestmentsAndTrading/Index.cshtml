@model BankingApp.Web.Models.Investments.InvestmentsPageViewModel

@{
    ViewData["Title"] = "Investments Portfolio";
    var portfolio = Model.Portfolio;
}

<div class="page-header mb-4">
    <h1 class="page-title">Investments & Trading</h1>
    <p class="page-subtitle mb-0">Monitor asset allocations, evaluate net returns, and submit live exchange executions.</p>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <section class="mb-4">
            <h2 class="h6 text-muted fw-semibold mb-3">Portfolio Valuation</h2>
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="mb-4">
                        <div class="stat-label small text-muted fw-semibold text-uppercase letter-spacing-wide mb-1">Total Portfolio Value</div>
                        <h3 class="stat-value fw-bold text-primary mb-0">@portfolio.TotalValue.ToString("N2") RON</h3>
                    </div>
                    <hr class="divider" />
                    <div>
                        <div class="stat-label small text-muted fw-semibold text-uppercase letter-spacing-wide mb-1">Total Profit / Loss</div>
                        @{
                            var isPositive = portfolio.TotalGainLoss >= 0;
                            var glClass = isPositive ? "amount-credit" : "amount-debit";
                            var glSign = isPositive ? "+" : "";
                        }
                        <h4 class="fw-bold @glClass mb-0">@glSign@portfolio.TotalGainLoss.ToString("N2") RON</h4>
                        <span class="small fw-semibold @glClass">(@((portfolio.GainLossPercent * 100).ToString("N2"))%)</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-4">
            <h2 class="h6 text-muted fw-semibold mb-3">Actions & Filters</h2>
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="list-group list-group-flush border rounded-3 mb-3" id="filterButtonGroup">
                        <button type="button" class="list-group-item list-group-item-action filter-item active border-bottom" data-filter="All">All Asset Classes</button>
                        <button type="button" class="list-group-item list-group-item-action filter-item border-bottom" data-filter="Stock">Equities / Stocks</button>
                        <button type="button" class="list-group-item list-group-item-action filter-item" data-filter="Crypto">Cryptocurrencies</button>
                    </div>
                    <a asp-action="Trade" class="btn btn-primary btn-full fw-medium">
                        <i class="bi bi-graph-up-arrow me-1"></i>Trade Assets
                    </a>
                </div>
            </div>
        </section>
    </div>

    <div class="col-lg-8">
        <section class="mb-4">
            <h2 class="h6 text-muted fw-semibold mb-3">Asset Positions</h2>
            <div class="card border-0 shadow-sm">
                @if (portfolio.Holdings != null && portfolio.Holdings.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="webHoldingsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Asset Ticker</th>
                                    <th>Classification</th>
                                    <th class="text-end">Owned Quantity</th>
                                    <th class="text-end">Avg Position Cost</th>
                                    <th class="text-end">Live Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var holding in portfolio.Holdings)
                                {
                                    <tr class="holding-row-item" data-type="@holding.AssetType">
                                        <td><span class="fw-bold text-dark">@holding.Ticker</span></td>
                                        <td><span class="badge rounded-pill bg-light text-secondary border fw-normal">@holding.AssetType</span></td>
                                        <td class="text-end font-monospace fw-semibold">@holding.Quantity.ToString("N4")</td>
                                        <td class="text-end font-monospace text-muted">@holding.AvgPurchasePrice.ToString("N2") RON</td>
                                        <td class="text-end font-monospace text-primary fw-semibold">@holding.CurrentPrice.ToString("N2") RON</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="card-body text-center py-5">
                        <i class="bi bi-wallet2 fs-1 text-muted mb-3 d-block"></i>
                        <h5 class="text-muted mb-2">No active holding positions</h5>
                        <p class="text-muted mb-0">Your investments will appear here once you execute a trade.</p>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.filter-item').click(function () {
                $('.filter-item').removeClass('active');
                $(this).addClass('active');

                var selectedAssetFilter = $(this).data('filter');

                if (selectedAssetFilter === 'All') {
                    $('.holding-row-item').show();
                } else {
                    $('.holding-row-item').hide();
                    $('.holding-row-item[data-type="' + selectedAssetFilter + '"]').show();
                }
            });
        });
    </script>
}