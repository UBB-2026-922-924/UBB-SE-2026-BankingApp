@model BankingApp.Web.Models.Investments.TradePageViewModel

@{
    ViewData["Title"] = "Crypto Exchange Trading";
    decimal currentAvailableBalance = Model.WalletBalance;
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none text-secondary small fw-medium">
        <i class="bi bi-arrow-left me-1"></i>Back to Portfolio Overview
    </a>
</div>

<div class="page-header mb-4">
    <h1 class="page-title">Execute Crypto Order</h1>
    <p class="page-subtitle mb-0">Place real-time market execution buy or sell orders for assets.</p>
</div>

<div class="alert flash-message alert-warning d-flex align-items-center gap-3 mb-4" role="alert" style="max-width: 700px;">
    <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0"></i>
    <div>
        <strong>High Volatility Asset Warning</strong>
        <div class="small">Digital crypto asset metrics change rapidly. Ensure target capitalization bounds fit your strategy risks before trading.</div>
    </div>
</div>

<section class="mb-4" style="max-width: 700px;">
    <h2 class="h6 text-muted fw-semibold mb-3">Order Details</h2>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="ExecuteTrade" method="post" id="webTradingForm">
                <div class="form-group mb-4">
                    <label for="ticker" class="form-label">Select Asset Token</label>
                    <select class="form-select" id="ticker" name="ticker">
                        <option value="BTC" selected>BTC (Bitcoin)</option>
                        <option value="ETH">ETH (Ethereum)</option>
                        <option value="SOL">SOL (Solana)</option>
                    </select>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label d-block">Transaction Path</label>
                    <div class="form-check form-check-inline me-4">
                        <input class="form-check-input" type="radio" name="actionType" id="typeBuy" value="BUY" checked>
                        <label class="form-check-label fw-medium text-success" for="typeBuy">Buy Position</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="actionType" id="typeSell" value="SELL">
                        <label class="form-check-label fw-medium text-danger" for="typeSell">Sell Position</label>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label for="quantity" class="form-label">Volume / Quantity</label>
                    <input type="number" class="form-control font-monospace" id="quantity" name="quantity" step="0.0001" min="0.0001" placeholder="0.0000" required autocomplete="off" />
                </div>

                <div id="webClientFeedbackMessage" class="alert flash-message d-none py-2 mb-4 small fw-medium"></div>

                <div class="card bg-light border-0 p-3 mb-4 shadow-none">
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Portfolio Spending Limit:</span>
                        <span id="labelCashLimit" class="font-monospace fw-bold text-dark" data-balance="@currentAvailableBalance">@currentAvailableBalance.ToString("N2") RON</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Execution Fee (1.5%):</span>
                        <span id="labelWebFee" class="font-monospace text-dark">0.00 RON</span>
                    </div>
                    <hr class="divider my-2" />
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="fw-bold text-dark">Estimated Order Total:</span>
                        <span id="labelWebTotal" class="h5 mb-0 fw-bold text-primary font-monospace">0.00 RON</span>
                    </div>
                </div>

                <button type="submit" id="btnWebSubmitOrder" class="btn btn-primary btn-full fw-bold">Submit Market Order</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            function updateCryptoExchangeTotals() {
                var selectedToken = $('#ticker').val();
                var rawQuantityValue = $('#quantity').val();
                var chosenActionType = $('input[name="actionType"]:checked').val();
                var cashThresholdLimit = parseFloat($('#labelCashLimit').data('balance'));

                var numericQty = parseFloat(rawQuantityValue);
                if (isNaN(numericQty) || numericQty <= 0) {
                    $('#labelWebFee').text('0.00 RON');
                    $('#labelWebTotal').text('0.00 RON');
                    $('#webClientFeedbackMessage').addClass('d-none').text('');
                    $('#btnWebSubmitOrder').prop('disabled', false);
                    return;
                }

                var priceScalarValue = 0;
                switch (selectedToken) {
                    case 'BTC': priceScalarValue = 65000.00; break;
                    case 'ETH': priceScalarValue = 2550.00; break;
                    case 'SOL': priceScalarValue = 145.00; break;
                }

                var baseCostValuation = numericQty * priceScalarValue;
                var estimatedFeeNode = Math.round((baseCostValuation * 0.015) * 100) / 100;
                var netCalculatedTotal = Math.round((baseCostValuation + estimatedFeeNode) * 100) / 100;

                $('#labelWebFee').text(estimatedFeeNode.toLocaleString('en-US', { minimumFractionDigits: 2 }) + ' RON');
                $('#labelWebTotal').text(netCalculatedTotal.toLocaleString('en-US', { minimumFractionDigits: 2 }) + ' RON');

                $('#webClientFeedbackMessage')
                    .removeClass('d-none alert-danger alert-info')
                    .addClass('alert-info')
                    .html('<i class="bi bi-info-circle-fill me-2"></i>Routing network quotes at ' + priceScalarValue.toLocaleString('en-US') + ' RON valuation per unit token.');

                if (chosenActionType === 'BUY' && netCalculatedTotal > cashThresholdLimit) {
                    $('#webClientFeedbackMessage')
                        .removeClass('alert-info')
                        .addClass('alert-danger')
                        .html('<i class="bi bi-exclamation-triangle-fill me-2"></i>Order execution locked: Total value limits exceed portfolio spending margins.');
                    $('#btnWebSubmitOrder').prop('disabled', true);
                } else {
                    $('#btnWebSubmitOrder').prop('disabled', false);
                }
            }

            $('#quantity').on('input', updateCryptoExchangeTotals);
            $('#ticker').on('change', updateCryptoExchangeTotals);
            $('input[name="actionType"]').on('change', updateCryptoExchangeTotals);
        });
    </script>
}