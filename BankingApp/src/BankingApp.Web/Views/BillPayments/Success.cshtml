@model BankingApp.Web.Models.BillPayments.BillPaySuccessModel
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-check-circle me-2 text-success"></i>Payment Successful</h1>
    <p class="page-subtitle">Your bill payment has been processed.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="card mb-4">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-receipt text-success"></i>
                <span>Payment Receipt</span>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                        <tr>
                            <th class="ps-3 py-3 text-muted-sm fw-600" style="width:45%">Receipt Number</th>
                            <td class="py-3 fw-700 font-monospace">@Model.ReceiptNumber</td>
                        </tr>
                        <tr>
                            <th class="ps-3 py-3 text-muted-sm fw-600">Biller</th>
                            <td class="py-3 fw-600">@Model.BillerName</td>
                        </tr>
                        <tr>
                            <th class="ps-3 py-3 text-muted-sm fw-600">Amount</th>
                            <td class="py-3">@Model.Currency @Model.Amount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <th class="ps-3 py-3 text-muted-sm fw-600">Fee</th>
                            <td class="py-3 text-warning">@Model.Currency @Model.Fee.ToString("N2")</td>
                        </tr>
                        <tr class="table-light">
                            <th class="ps-3 py-3 fw-700">Total Debited</th>
                            <td class="py-3 fw-700 amount-debit fs-5">@Model.Currency @Model.Total.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Pay Another Bill
            </a>
            <a asp-action="History" class="btn btn-outline-secondary">
                <i class="bi bi-clock-history me-1"></i>Payment History
            </a>
        </div>

    </div>
</div>
