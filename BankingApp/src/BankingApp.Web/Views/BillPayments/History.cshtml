@model BankingApp.Web.Models.BillPayments.BillPaymentHistoryModel
@{
    ViewData["Title"] = "Payment History";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-clock-history me-2 text-primary"></i>Payment History</h1>
        <p class="page-subtitle">All bill payments made from your accounts.</p>
    </div>
    <a asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>New Payment
    </a>
</div>

@if (!Model.HasPayments)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-receipt fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No payments yet</h5>
            <p class="text-muted mb-4">Your bill-payment history will appear here once you make a payment.</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Make a Payment
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="historyTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Receipt</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Payments)
                        {
                            <partial name="_TransactionRow" model="@TransactionRowViewModel.FromBillPayment(row)" />
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="text-muted-sm">@Model.Payments.Count payment(s)</span>
            <span class="text-muted-sm">
                Total paid:
                <strong class="amount-debit">@Model.Payments.Sum(p => p.Total).ToString("N2")</strong>
            </span>
        </div>
    </div>
}
