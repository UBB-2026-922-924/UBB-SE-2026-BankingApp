@model BankingApp.Web.Models.BillPayments.BillPayModel
@{
    ViewData["Title"] = "Pay a Bill";
    var billerCategories = Model.AllBillers
        .Select(biller => biller.Category)
        .Where(category => !string.IsNullOrWhiteSpace(category))
        .Distinct()
        .OrderBy(category => category)
        .ToList();
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-receipt me-2 text-primary"></i>Pay a Bill</h1>
        <p class="page-subtitle">Choose a biller, enter an amount and preview the fee before confirming.</p>
    </div>
    <a asp-action="History" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-clock-history me-1"></i>Payment History
    </a>
</div>

<div class="row g-4">

    <div class="col-lg-5 col-xl-4">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-bookmark-heart text-primary"></i>
                <span>Saved Billers</span>
                <span class="badge bg-primary ms-auto">@Model.SavedBillers.Count</span>
            </div>
            <div class="card-body p-2">
                @if (!Model.SavedBillers.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-bookmark-plus fs-2 text-muted"></i>
                        <p class="text-muted mt-2 mb-0 small">No saved billers yet.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush saved-billers-list" id="savedBillersList">
                        @foreach (var savedBiller in Model.SavedBillers)
                        {
                            <partial name="_BillerCard" model="@BillerCardViewModel.FromSavedBiller(savedBiller)" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7 col-xl-8">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-send text-primary"></i>
                <span>Payment Details</span>
            </div>
            <div class="card-body">

                <form asp-action="Preview" method="post" id="billPayForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Biller search and category filter -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="bi bi-search me-1"></i>Search Billers
                        </label>
                        <div class="row g-2">
                            <div class="col-sm-8">
                                <input type="text"
                                       class="form-control"
                                       id="billerSearch"
                                       placeholder="Search billers..."
                                       autocomplete="off" />
                            </div>
                            <div class="col-sm-4">
                                <select class="form-select" id="categoryFilter">
                                    <option value="">All categories</option>
                                    @foreach (var category in billerCategories)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Biller -->
                    <div class="form-group">
                        <label asp-for="SelectedBillerId" class="form-label">
                            <i class="bi bi-building me-1"></i>Biller
                        </label>
                        <select asp-for="SelectedBillerId"
                                class="form-select"
                                id="billerSelect">
                            <option value="0">— Select a biller —</option>
                            @foreach (var biller in Model.AllBillers)
                            {
                                <option value="@biller.Id"
                                        data-category="@biller.Category"
                                        data-name="@biller.Name.ToLowerInvariant()">
                                    @biller.Name (@biller.Category)
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SelectedBillerId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Source account -->
                    <div class="form-group">
                        <label asp-for="SelectedAccountId" class="form-label">
                            <i class="bi bi-bank me-1"></i>From Account
                        </label>
                        <select asp-for="SelectedAccountId"
                                class="form-select"
                                id="accountSelect">
                            <option value="0">— Select an account —</option>
                            @foreach (var account in Model.Accounts)
                            {
                                var cardDisplay = account.CardLastFourDigits != null
                                    ? $"card ending {account.CardLastFourDigits}"
                                    : "no card";
                                <option value="@account.Id"
                                        data-currency="@account.Currency">
                                    @account.AccountName — @cardDisplay (@account.Currency) | Balance: @account.Balance.ToString("N2")
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SelectedAccountId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Biller reference -->
                    <div class="form-group">
                        <label asp-for="BillerReference" class="form-label">
                            <i class="bi bi-hash me-1"></i>Biller Reference / Account Number
                        </label>
                        <input asp-for="BillerReference"
                               class="form-control"
                               id="billerRef"
                               placeholder="e.g. INV-00123 or your customer number"
                               autocomplete="off" />
                        <span asp-validation-for="BillerReference" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Amount -->
                    <div class="form-group">
                        <label asp-for="Amount" class="form-label">
                            <i class="bi bi-cash me-1"></i>Amount
                        </label>
                        <div class="input-group">
                            <span class="input-group-text" id="currencySymbol">RON</span>
                            <input asp-for="Amount"
                                   type="number"
                                   step="0.01"
                                   min="0.01"
                                   class="form-control"
                                   id="amountInput"
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="invalid-feedback d-block"></span>

                        <!-- Live fee preview hint (populated from backend via fee endpoint) -->
                        <div class="mt-2 small text-muted" id="feeHint" style="display:none;">
                            <i class="bi bi-info-circle me-1"></i>
                            Estimated fee: <strong id="feeHintValue"></strong>
                        </div>
                    </div>

                    <!-- Save biller toggle -->
                    <div class="form-group">
                        <div class="form-check form-switch">
                            <input asp-for="ShouldSaveBiller"
                                   class="form-check-input"
                                   type="checkbox"
                                   role="switch"
                                   id="shouldSaveBiller" />
                            <label class="form-check-label" for="shouldSaveBiller">
                                <i class="bi bi-bookmark-plus me-1"></i>Save this biller for future payments
                            </label>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <button type="submit" class="btn btn-primary btn-full" id="previewBtn">
                        <i class="bi bi-eye me-2"></i>Preview Payment
                    </button>
                </form>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Pre-fill form when a saved biller card is clicked
        document.querySelectorAll('.saved-biller-item').forEach(btn => {
            btn.addEventListener('click', () => {
                const billerId = btn.dataset.billerId;
                const billerRef = btn.dataset.billerRef ?? '';
                document.getElementById('billerSelect').value = billerId;
                document.getElementById('billerRef').value = billerRef;
                document.getElementById('amountInput').focus();
                document.querySelectorAll('.saved-biller-item').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Biller search and category filter
        const billerSearch = document.getElementById('billerSearch');
        const categoryFilter = document.getElementById('categoryFilter');
        const billerSelect = document.getElementById('billerSelect');

        function filterBillers() {
            const searchText = billerSearch.value.toLowerCase();
            const selectedCategory = categoryFilter.value.toLowerCase();
            const options = billerSelect.querySelectorAll('option[data-name]');
            options.forEach(option => {
                const billerName = option.dataset.name ?? '';
                const billerCategory = (option.dataset.category ?? '').toLowerCase();
                const matchesSearch = searchText === '' || billerName.includes(searchText);
                const matchesCategory = selectedCategory === '' || billerCategory === selectedCategory;
                option.hidden = !(matchesSearch && matchesCategory);
            });
            // Reset selection if the currently selected option is now hidden
            const selectedOption = billerSelect.options[billerSelect.selectedIndex];
            if (selectedOption && selectedOption.hidden) {
                billerSelect.value = '0';
            }
        }

        billerSearch.addEventListener('input', filterBillers);
        categoryFilter.addEventListener('change', filterBillers);

        // Update currency symbol when account is selected
        const accountSelect = document.getElementById('accountSelect');
        const currencySymbol = document.getElementById('currencySymbol');
        accountSelect.addEventListener('change', () => {
            const selectedOption = accountSelect.options[accountSelect.selectedIndex];
            const currency = selectedOption?.dataset.currency ?? 'RON';
            currencySymbol.textContent = currency;
            updateFeeHint();
        });

        // Live fee preview fetched from backend
        const amountInput = document.getElementById('amountInput');
        const feeHint = document.getElementById('feeHint');
        const feeHintValue = document.getElementById('feeHintValue');

        async function updateFeeHint() {
            const amount = parseFloat(amountInput.value) || 0;
            if (amount <= 0) {
                feeHint.style.display = 'none';
                return;
            }

            try {
                const response = await fetch(`/api/bill-payment/fee?amount=${amount}`, {
                    headers: { 'Accept': 'application/json' }
                });
                if (!response.ok) {
                    feeHint.style.display = 'none';
                    return;
                }
                const data = await response.json();
                const currency = currencySymbol.textContent;
                feeHintValue.textContent = currency + ' ' + data.fee.toFixed(2);
                feeHint.style.display = '';
            } catch {
                feeHint.style.display = 'none';
            }
        }

        amountInput.addEventListener('input', updateFeeHint);
    </script>
}
