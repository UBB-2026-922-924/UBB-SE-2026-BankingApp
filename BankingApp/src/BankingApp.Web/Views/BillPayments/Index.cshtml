@model BankingApp.Web.Models.BillPayments.BillPayModel
@{
    ViewData["Title"] = "Pay a Bill";
    var billerCategories = Model.AllBillers
        .Select(biller => biller.Category)
        .Where(category => !string.IsNullOrWhiteSpace(category))
        .Distinct()
        .OrderBy(category => category)
        .ToList();

    var savedReferenceByBillerId = Model.SavedBillers
        .GroupBy(savedBiller => savedBiller.BillerId)
        .ToDictionary(group => group.Key, group => group.First().DefaultReference ?? string.Empty);
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-receipt me-2 text-primary"></i>Pay a Bill</h1>
        <p class="page-subtitle">Choose a biller, enter an amount and preview the fee before confirming.</p>
    </div>
    <a asp-action="History" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-clock-history me-1"></i>Payment History
    </a>
</div>

<div class="row g-4">

    <div class="col-lg-5 col-xl-4">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-bookmark-heart text-primary"></i>
                <span>Saved Billers</span>
                <span class="badge bg-primary ms-auto">@Model.SavedBillers.Count</span>
            </div>
            <div class="card-body p-2">
                @if (!Model.SavedBillers.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-bookmark-plus fs-2 text-muted"></i>
                        <p class="text-muted mt-2 mb-0 small">No saved billers yet.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush saved-billers-list" id="savedBillersList">
                        @foreach (var savedBiller in Model.SavedBillers)
                        {
                            var card = BillerCardViewModel.FromSavedBiller(savedBiller);
                            <div class="list-group-item d-flex align-items-center gap-1 p-0">
                                <button type="button"
                                        class="saved-biller-item flex-grow-1 d-flex align-items-center gap-3 text-start border-0 bg-transparent py-3 ps-3 pe-1 m-0 overflow-hidden"
                                        data-biller-id="@card.BillerId"
                                        data-biller-ref="@card.DefaultReference"
                                        title="Click to pre-fill the form">
                                    @if (!string.IsNullOrWhiteSpace(card.LogoUrl))
                                    {
                                        <img src="@card.LogoUrl" alt="@card.DisplayName"
                                             class="rounded flex-shrink-0" width="36" height="36"
                                             style="object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <span class="biller-icon-placeholder rounded d-flex align-items-center justify-content-center flex-shrink-0"
                                              style="width:36px;height:36px;background:var(--ba-surface);">
                                            <i class="bi bi-building text-primary"></i>
                                        </span>
                                    }
                                    <span class="flex-grow-1 overflow-hidden">
                                        <span class="d-block fw-600 text-truncate small">@card.DisplayName</span>
                                        <span class="d-block text-muted-sm text-truncate">@card.Category</span>
                                    </span>
                                </button>
                                <form asp-controller="BillPayments"
                                      asp-action="RemoveSavedBiller"
                                      asp-route-savedBillerId="@savedBiller.Id"
                                      method="post"
                                      class="flex-shrink-0 pe-2">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-link text-danger p-1 lh-1 d-flex align-items-center saved-biller-remove"
                                            title="Remove saved biller"
                                            aria-label="Remove saved biller">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7 col-xl-8">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-send text-primary"></i>
                <span>Payment Details</span>
            </div>
            <div class="card-body">

                <form asp-action="Preview" method="post" id="billPayForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Biller search and category filter -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="bi bi-search me-1"></i>Search Billers
                        </label>
                        <div class="row g-2">
                            <div class="col-sm-8">
                                <input type="text"
                                       class="form-control"
                                       id="billerSearch"
                                       placeholder="Search billers..."
                                       autocomplete="off" />
                            </div>
                            <div class="col-sm-4">
                                <select class="form-select" id="categoryFilter">
                                    <option value="">All categories</option>
                                    @foreach (var category in billerCategories)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Biller -->
                    <div class="form-group">
                        <label asp-for="SelectedBillerId" class="form-label">
                            <i class="bi bi-building me-1"></i>Biller
                        </label>
                        <input type="hidden" asp-for="SelectedBillerId" id="selectedBillerId" />
                        <div class="list-group biller-listview border rounded"
                             id="billerListView"
                             style="max-height: 280px; overflow-y: auto;">
                            @foreach (var biller in Model.AllBillers)
                            {
                                var isSaved = savedReferenceByBillerId.ContainsKey(biller.Id);
                                var savedRef = isSaved ? savedReferenceByBillerId[biller.Id] : string.Empty;
                                <button type="button"
                                        class="list-group-item list-group-item-action biller-list-item d-flex justify-content-between align-items-center"
                                        data-biller-id="@biller.Id"
                                        data-name="@biller.Name.ToLowerInvariant()"
                                        data-category="@biller.Category"
                                        data-saved="@isSaved.ToString().ToLowerInvariant()"
                                        data-biller-ref="@savedRef">
                                    <span class="text-truncate">
                                        <i class="bi bi-building me-2 text-primary"></i>@biller.Name
                                    </span>
                                    <span class="badge bg-light text-secondary ms-2">@biller.Category</span>
                                </button>
                            }
                        </div>
                        <div class="text-muted small mt-1 d-none" id="noBillersHint">
                            <i class="bi bi-info-circle me-1"></i>No billers match your search.
                        </div>
                        <span asp-validation-for="SelectedBillerId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Source account -->
                    <div class="form-group">
                        <label asp-for="SelectedAccountId" class="form-label">
                            <i class="bi bi-bank me-1"></i>From Account
                        </label>
                        <select asp-for="SelectedAccountId"
                                class="form-select"
                                id="accountSelect">
                            <option value="0">— Select an account —</option>
                            @foreach (var account in Model.Accounts)
                            {
                                var cardDisplay = account.CardLastFourDigits != null
                                    ? $"card ending {account.CardLastFourDigits}"
                                    : "no card";
                                <option value="@account.Id"
                                        data-currency="@account.Currency">
                                    @account.Iban — @cardDisplay (@account.Currency) | Balance: @account.Balance.ToString("N2")
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SelectedAccountId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Biller reference -->
                    <div class="form-group">
                        <label asp-for="BillerReference" class="form-label">
                            <i class="bi bi-hash me-1"></i>Biller Reference / Account Number
                        </label>
                        <input asp-for="BillerReference"
                               class="form-control"
                               id="billerRef"
                               placeholder="e.g. INV-00123 or your customer number"
                               autocomplete="off" />
                        <span asp-validation-for="BillerReference" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Amount -->
                    <div class="form-group">
                        <label asp-for="Amount" class="form-label">
                            <i class="bi bi-cash me-1"></i>Amount
                        </label>
                        <div class="input-group">
                            <span class="input-group-text" id="currencySymbol">RON</span>
                            <input asp-for="Amount"
                                   type="number"
                                   step="0.01"
                                   min="0.01"
                                   class="form-control"
                                   id="amountInput"
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="invalid-feedback d-block"></span>

                        <!-- Live fee preview hint (populated from backend via fee endpoint) -->
                        <div class="mt-2 small text-muted" id="feeHint" style="display:none;">
                            <i class="bi bi-info-circle me-1"></i>
                            Estimated fee: <strong id="feeHintValue"></strong>
                        </div>
                    </div>

                    <!-- Save biller toggle -->
                    <div class="form-group">
                        <div class="form-check form-switch">
                            <input asp-for="ShouldSaveBiller"
                                   class="form-check-input"
                                   type="checkbox"
                                   role="switch"
                                   id="shouldSaveBiller" />
                            <label class="form-check-label" for="shouldSaveBiller">
                                <i class="bi bi-bookmark-plus me-1"></i>Save this biller for future payments
                            </label>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <button type="submit" class="btn btn-primary btn-full" id="previewBtn">
                        <i class="bi bi-eye me-2"></i>Preview Payment
                    </button>
                </form>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const billerSearch = document.getElementById('billerSearch');
        const categoryFilter = document.getElementById('categoryFilter');
        const billerListView = document.getElementById('billerListView');
        const billerItems = Array.from(billerListView.querySelectorAll('.biller-list-item'));
        const selectedBillerIdInput = document.getElementById('selectedBillerId');
        const billerRefInput = document.getElementById('billerRef');
        const saveBillerToggle = document.getElementById('shouldSaveBiller');
        const noBillersHint = document.getElementById('noBillersHint');

        // Select a biller from the list view, reflecting its saved state on the toggle.
        function selectBiller(item, prefillReference) {
            billerItems.forEach(other => other.classList.remove('active'));
            item.classList.add('active');
            selectedBillerIdInput.value = item.dataset.billerId;

            const isSaved = item.dataset.saved === 'true';
            saveBillerToggle.checked = isSaved;

            const savedRef = item.dataset.billerRef ?? '';
            if (prefillReference && isSaved && savedRef !== '') {
                billerRefInput.value = savedRef;
            }
        }

        billerItems.forEach(item => {
            item.addEventListener('click', () => selectBiller(item, true));
        });

        // Pre-fill the form and select the matching list item when a saved biller card is clicked.
        document.querySelectorAll('.saved-biller-item').forEach(btn => {
            btn.addEventListener('click', () => {
                const billerId = btn.dataset.billerId;
                const billerRef = btn.dataset.billerRef ?? '';
                const match = billerItems.find(item => item.dataset.billerId === billerId);
                if (match) {
                    selectBiller(match, false);
                    match.scrollIntoView({ block: 'nearest' });
                }
                billerRefInput.value = billerRef;
                document.getElementById('amountInput').focus();
                document.querySelectorAll('.saved-biller-item').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Biller search and category filter narrow the visible list items.
        function filterBillers() {
            const searchText = billerSearch.value.toLowerCase();
            const selectedCategory = categoryFilter.value.toLowerCase();
            let visibleCount = 0;
            billerItems.forEach(item => {
                const billerName = item.dataset.name ?? '';
                const billerCategory = (item.dataset.category ?? '').toLowerCase();
                const matchesSearch = searchText === '' || billerName.includes(searchText);
                const matchesCategory = selectedCategory === '' || billerCategory === selectedCategory;
                item.classList.toggle('d-none', !(matchesSearch && matchesCategory));
                if (matchesSearch && matchesCategory) {
                    visibleCount++;
                }
            });
            noBillersHint.classList.toggle('d-none', visibleCount > 0);

            // Clear the selection if the currently selected biller is now hidden.
            const selected = billerItems.find(item => item.classList.contains('active'));
            if (selected && selected.classList.contains('d-none')) {
                selected.classList.remove('active');
                selectedBillerIdInput.value = '0';
            }
        }

        billerSearch.addEventListener('input', filterBillers);
        categoryFilter.addEventListener('change', filterBillers);

        // Restore the highlighted item when the form re-renders with a chosen biller.
        const initialBillerId = selectedBillerIdInput.value;
        if (initialBillerId && initialBillerId !== '0') {
            const initialMatch = billerItems.find(item => item.dataset.billerId === initialBillerId);
            if (initialMatch) {
                initialMatch.classList.add('active');
            }
        }

        // Update currency symbol when account is selected
        const accountSelect = document.getElementById('accountSelect');
        const currencySymbol = document.getElementById('currencySymbol');
        accountSelect.addEventListener('change', () => {
            const selectedOption = accountSelect.options[accountSelect.selectedIndex];
            const currency = selectedOption?.dataset.currency ?? 'RON';
            currencySymbol.textContent = currency;
            updateFeeHint();
        });

        // Live fee preview fetched from backend
        const amountInput = document.getElementById('amountInput');
        const feeHint = document.getElementById('feeHint');
        const feeHintValue = document.getElementById('feeHintValue');

        async function updateFeeHint() {
            const amount = parseFloat(amountInput.value) || 0;
            if (amount <= 0) {
                feeHint.style.display = 'none';
                return;
            }

            try {
                const response = await fetch(`/api/bill-payment/fee?amount=${amount}`, {
                    headers: { 'Accept': 'application/json' }
                });
                if (!response.ok) {
                    feeHint.style.display = 'none';
                    return;
                }
                const data = await response.json();
                const currency = currencySymbol.textContent;
                feeHintValue.textContent = currency + ' ' + data.fee.toFixed(2);
                feeHint.style.display = '';
            } catch {
                feeHint.style.display = 'none';
            }
        }

        amountInput.addEventListener('input', updateFeeHint);
    </script>
}
