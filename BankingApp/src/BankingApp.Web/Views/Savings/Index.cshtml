@model BankingApp.Web.Models.Savings.SavingsPageViewModel
@{
    ViewData["Title"] = "Savings";
    var selectedAccount = Model.SelectedAccount;
}

<div class="finance-page">
    @await Html.PartialAsync("_FinanceTabs", "savings")

    <section class="hero-panel">
        <div class="hero-copy">
            <span class="hero-kicker">Savings hub</span>
            <h1>Grow your safety net with clarity.</h1>
            <p>Open accounts, move money, automate deposits, and watch goal progress from a single web workspace.</p>
        </div>
        <div class="hero-metrics">
            <article class="metric-card">
                <span>Total saved</span>
                <strong>@Model.TotalSavedAmount</strong>
                <small>@Model.NumberOfAccountsText</small>
            </article>
            <article class="metric-card">
                <span>Best APY</span>
                <strong>@Model.BestInterestRate</strong>
                <small>Across your active products</small>
            </article>
        </div>
    </section>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-4">
            <section class="surface-card h-100">
                <div class="section-title-wrap">
                    <span class="section-kicker">Open new</span>
                    <h2>New savings account</h2>
                </div>

                <form asp-action="CreateAccount" method="post" class="stack-form">
                    @Html.AntiForgeryToken()

                    <div>
                        <label asp-for="CreateAccount.SelectedSavingsType" class="form-label"></label>
                        <select asp-for="CreateAccount.SelectedSavingsType" class="form-select js-savings-type">
                            <option value="">Select a type</option>
                            <option value="Standard">Standard</option>
                            <option value="HighYield">High Yield</option>
                            <option value="GoalSavings">Goal Savings</option>
                            <option value="FixedDeposit">Fixed Deposit</option>
                        </select>
                        <span asp-validation-for="CreateAccount.SelectedSavingsType" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="CreateAccount.AccountName" class="form-label"></label>
                        <input asp-for="CreateAccount.AccountName" class="form-control" placeholder="Emergency fund" />
                        <span asp-validation-for="CreateAccount.AccountName" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="CreateAccount.InitialDeposit" class="form-label"></label>
                            <input asp-for="CreateAccount.InitialDeposit" class="form-control" placeholder="1000" />
                            <span asp-validation-for="CreateAccount.InitialDeposit" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="CreateAccount.FundingSourceId" class="form-label"></label>
                            <select asp-for="CreateAccount.FundingSourceId" class="form-select">
                                <option value="">Select source</option>
                                @foreach (var source in Model.FundingSources)
                                {
                                    <option value="@source.Id">@source.DisplayName</option>
                                }
                            </select>
                            <span asp-validation-for="CreateAccount.FundingSourceId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="CreateAccount.SelectedFrequency" class="form-label"></label>
                        <select asp-for="CreateAccount.SelectedFrequency" class="form-select">
                            <option value="OneTime">One time</option>
                            <option value="Daily">Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                        <span asp-validation-for="CreateAccount.SelectedFrequency" class="text-danger small"></span>
                    </div>

                    <div class="goal-settings @(string.Equals(Model.CreateAccount.SelectedSavingsType, "GoalSavings", StringComparison.OrdinalIgnoreCase) ? string.Empty : "d-none")">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label asp-for="CreateAccount.TargetAmount" class="form-label"></label>
                                <input asp-for="CreateAccount.TargetAmount" class="form-control" placeholder="5000" />
                                <span asp-validation-for="CreateAccount.TargetAmount" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="CreateAccount.TargetDate" class="form-label"></label>
                                <input asp-for="CreateAccount.TargetDate" class="form-control" type="date" />
                                <span asp-validation-for="CreateAccount.TargetDate" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="fixed-settings @(string.Equals(Model.CreateAccount.SelectedSavingsType, "FixedDeposit", StringComparison.OrdinalIgnoreCase) ? string.Empty : "d-none")">
                        <label asp-for="CreateAccount.MaturityDate" class="form-label"></label>
                        <input asp-for="CreateAccount.MaturityDate" class="form-control" type="date" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Open account</button>
                </form>
            </section>
        </div>

        <div class="col-12 col-xl-8">
            <section class="surface-card manage-card">
                <div class="section-title-wrap">
                    <span class="section-kicker">Manage</span>
                    <h2>Selected account</h2>
                </div>

                @if (selectedAccount == null)
                {
                    <div class="empty-panel">
                        <h3>No active savings accounts</h3>
                        <p>Create your first savings product to unlock deposits, withdrawals, automation, and account closure controls.</p>
                    </div>
                }
                else
                {
                    <div class="account-highlight">
                        <div>
                            <h3>@selectedAccount.AccountName</h3>
                            <p>@selectedAccount.SavingsType account</p>
                        </div>
                        <div class="account-highlight-meta">
                            <strong>@selectedAccount.FormattedBalance</strong>
                            <span class="status-pill">@selectedAccount.DisplayStatus</span>
                        </div>
                    </div>

                    <div class="mini-metrics">
                        <div>
                            <span>APY</span>
                            <strong>@($"{selectedAccount.AnnualPercentageYield:P2}")</strong>
                        </div>
                        <div>
                            <span>Projected monthly</span>
                            <strong>@selectedAccount.MonthlyInterestProjection.ToString("C2")</strong>
                        </div>
                        <div>
                            <span>Maturity</span>
                            <strong>@(selectedAccount.MaturityDate?.ToString("dd MMM yyyy") ?? "Flexible")</strong>
                        </div>
                    </div>

                    @if (selectedAccount.TargetAmount.HasValue)
                    {
                        <div class="goal-progress">
                            <div class="d-flex justify-content-between">
                                <span>Goal progress</span>
                                <span>@selectedAccount.ProgressPercent.ToString("N0")%</span>
                            </div>
                            <div class="progress" role="progressbar" aria-valuenow="@selectedAccount.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width:@Math.Min(selectedAccount.ProgressPercent, 100)%"></div>
                            </div>
                        </div>
                    }

                    <ul class="nav nav-tabs manage-tabs" id="manageTabs" role="tablist" data-active-tab="@Model.ActiveManageTab">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveManageTab == "overview" ? "active" : string.Empty)" data-bs-toggle="tab" data-bs-target="#tab-overview" type="button" role="tab">Overview</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveManageTab == "deposit" ? "active" : string.Empty)" data-bs-toggle="tab" data-bs-target="#tab-deposit" type="button" role="tab">Deposit</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveManageTab == "withdraw" ? "active" : string.Empty)" data-bs-toggle="tab" data-bs-target="#tab-withdraw" type="button" role="tab">Withdraw</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveManageTab == "auto" ? "active" : string.Empty)" data-bs-toggle="tab" data-bs-target="#tab-auto" type="button" role="tab">Auto deposit</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveManageTab == "close" ? "active" : string.Empty)" data-bs-toggle="tab" data-bs-target="#tab-close" type="button" role="tab">Close</button>
                        </li>
                    </ul>

                    <div class="tab-content pt-4">
                        <div class="tab-pane fade @(Model.ActiveManageTab == "overview" ? "show active" : string.Empty)" id="tab-overview" role="tabpanel">
                            <div class="overview-grid">
                                <article class="info-card">
                                    <span>Status</span>
                                    <strong>@selectedAccount.DisplayStatus</strong>
                                    <p>Current lifecycle of the account.</p>
                                </article>
                                <article class="info-card">
                                    <span>Funding source</span>
                                    <strong>@(selectedAccount.FundingAccount?.AccountName ?? "Not linked")</strong>
                                    <p>Default source for opening and future movements.</p>
                                </article>
                                <article class="info-card">
                                    <span>Goal date</span>
                                    <strong>@(selectedAccount.TargetDate?.ToString("dd MMM yyyy") ?? "Not set")</strong>
                                    <p>Target and maturity milestones stay visible here.</p>
                                </article>
                            </div>
                        </div>

                        <div class="tab-pane fade @(Model.ActiveManageTab == "deposit" ? "show active" : string.Empty)" id="tab-deposit" role="tabpanel">
                            <form asp-action="Deposit" method="post" class="stack-form js-deposit-preview-form" data-preview-url="@Url.Action("DepositPreview", "Savings")">
                                @Html.AntiForgeryToken()
                                <input asp-for="Deposit.AccountId" type="hidden" />

                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <label asp-for="Deposit.Amount" class="form-label"></label>
                                        <input asp-for="Deposit.Amount" class="form-control js-deposit-amount" placeholder="0.00" />
                                    </div>
                                    <div class="col-sm-6">
                                        <label asp-for="Deposit.FundingSourceId" class="form-label"></label>
                                        <select asp-for="Deposit.FundingSourceId" class="form-select">
                                            <option value="">Select source</option>
                                            @foreach (var source in Model.FundingSources)
                                            {
                                                <option value="@source.Id">@source.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="soft-note js-deposit-preview">@Model.DepositPreview</div>
                                <button type="submit" class="btn btn-primary">Confirm deposit</button>
                            </form>
                        </div>

                        <div class="tab-pane fade @(Model.ActiveManageTab == "withdraw" ? "show active" : string.Empty)" id="tab-withdraw" role="tabpanel">
                            <form asp-action="Withdraw" method="post" class="stack-form js-withdraw-preview-form" data-preview-url="@Url.Action("WithdrawPreview", "Savings")">
                                @Html.AntiForgeryToken()
                                <input asp-for="Withdraw.AccountId" type="hidden" />

                                @if (Model.WithdrawPreview.HasEarlyRisk)
                                {
                                    <div class="alert alert-warning mb-0">
                                        @Model.WithdrawPreview.PenaltySummary
                                    </div>
                                }

                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <label asp-for="Withdraw.Amount" class="form-label"></label>
                                        <input asp-for="Withdraw.Amount" class="form-control js-withdraw-amount" placeholder="0.00" />
                                    </div>
                                    <div class="col-sm-6">
                                        <label asp-for="Withdraw.DestinationId" class="form-label"></label>
                                        <select asp-for="Withdraw.DestinationId" class="form-select">
                                            <option value="">Select destination</option>
                                            @foreach (var source in Model.FundingSources)
                                            {
                                                <option value="@source.Id">@source.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="soft-note js-withdraw-breakdown @(Model.WithdrawPreview.HasPenalty ? string.Empty : "d-none")">@Model.WithdrawPreview.PenaltyBreakdown</div>
                                <div class="soft-note strong js-withdraw-net @(string.IsNullOrWhiteSpace(Model.WithdrawPreview.NetAmountText) ? "d-none" : string.Empty)">@Model.WithdrawPreview.NetAmountText</div>
                                <button type="submit" class="btn btn-primary">Confirm withdrawal</button>
                            </form>
                        </div>

                        <div class="tab-pane fade @(Model.ActiveManageTab == "auto" ? "show active" : string.Empty)" id="tab-auto" role="tabpanel">
                            <form asp-action="SaveAutoDeposit" method="post" class="stack-form">
                                @Html.AntiForgeryToken()
                                <input asp-for="AutoDeposit.AccountId" type="hidden" />

                                <div class="row g-3">
                                    <div class="col-sm-4">
                                        <label asp-for="AutoDeposit.Amount" class="form-label"></label>
                                        <input asp-for="AutoDeposit.Amount" class="form-control" placeholder="250" />
                                    </div>
                                    <div class="col-sm-4">
                                        <label asp-for="AutoDeposit.Frequency" class="form-label"></label>
                                        <select asp-for="AutoDeposit.Frequency" class="form-select">
                                            <option value="Daily">Daily</option>
                                            <option value="Weekly">Weekly</option>
                                            <option value="Monthly">Monthly</option>
                                        </select>
                                    </div>
                                    <div class="col-sm-4">
                                        <label asp-for="AutoDeposit.StartDate" class="form-label"></label>
                                        <input asp-for="AutoDeposit.StartDate" class="form-control" type="date" />
                                    </div>
                                </div>

                                <div class="form-check form-switch">
                                    <input asp-for="AutoDeposit.IsActive" class="form-check-input" />
                                    <label asp-for="AutoDeposit.IsActive" class="form-check-label"></label>
                                </div>

                                <button type="submit" class="btn btn-primary">Save auto deposit</button>
                            </form>
                        </div>

                        <div class="tab-pane fade @(Model.ActiveManageTab == "close" ? "show active" : string.Empty)" id="tab-close" role="tabpanel">
                            <form asp-action="CloseAccount" method="post" class="stack-form">
                                @Html.AntiForgeryToken()
                                <input asp-for="CloseAccount.AccountId" type="hidden" />

                                @if (string.Equals(selectedAccount.SavingsType, "FixedDeposit", StringComparison.OrdinalIgnoreCase) && selectedAccount.MaturityDate.HasValue && selectedAccount.MaturityDate.Value > DateTime.UtcNow)
                                {
                                    <div class="alert alert-danger mb-0">
                                        This fixed deposit has not reached maturity yet. Closing it may apply an early penalty.
                                    </div>
                                }

                                <div>
                                    <label asp-for="CloseAccount.DestinationAccountId" class="form-label"></label>
                                    @if (Model.CloseDestinationAccounts.Count == 0)
                                    {
                                        <select asp-for="CloseAccount.DestinationAccountId" class="form-select" disabled>
                                            <option value="0">Select destination</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select asp-for="CloseAccount.DestinationAccountId" class="form-select">
                                            <option value="0">Select destination</option>
                                            @foreach (var destination in Model.CloseDestinationAccounts)
                                            {
                                                <option value="@destination.Id">@destination.AccountName</option>
                                            }
                                        </select>
                                    }
                                </div>

                                <div class="form-check">
                                    <input asp-for="CloseAccount.Confirmed" class="form-check-input" />
                                    <label asp-for="CloseAccount.Confirmed" class="form-check-label"></label>
                                </div>

                                <button type="submit" class="btn btn-outline-danger" @(Model.CloseDestinationAccounts.Count == 0 ? "disabled" : null)>Close account</button>
                            </form>
                        </div>
                    </div>
                }
            </section>
        </div>
    </div>

    <section class="surface-card mt-4">
        <div class="section-title-wrap">
            <span class="section-kicker">Portfolio</span>
            <h2>My accounts</h2>
        </div>

        @if (!Model.HasAccounts)
        {
            <div class="empty-panel compact">
                <h3>No savings accounts yet</h3>
                <p>Use the creation form to open the first account in this area.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var account in Model.Accounts)
                {
                    <div class="col-12 col-lg-6">
                        <a class="account-card @(selectedAccount?.Id == account.Id ? "active" : string.Empty)"
                           asp-action="Index"
                           asp-route-accountId="@account.Id"
                           asp-route-manageTab="@Model.ActiveManageTab">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <h3>@account.AccountName</h3>
                                    <p>@account.SavingsType</p>
                                </div>
                                <span class="status-pill">@account.DisplayStatus</span>
                            </div>
                            <strong>@account.FormattedBalance</strong>
                            <div class="account-meta">
                                <span>APY @($"{account.AnnualPercentageYield:P2}")</span>
                                <span>Monthly @account.MonthlyInterestProjection.ToString("C2")</span>
                            </div>
                            @if (account.TargetAmount.HasValue)
                            {
                                <div class="progress mt-3" role="progressbar" aria-valuenow="@account.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar" style="width:@Math.Min(account.ProgressPercent, 100)%"></div>
                                </div>
                            }
                        </a>
                    </div>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
