@model BankingApp.Web.Models.Transfers.TransferIbanValidatedModel
@{
    ViewData["Title"] = "New Transfer — Account & Amount";
}

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-send me-2 text-primary"></i>New Transfer</h1>
    <p class="page-subtitle">IBAN validated. Select your account, enter amount and recipient details.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <!-- Validated IBAN info -->
        <div class="card mb-4">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill text-success"></i>
                <span>Recipient Verified</span>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted-sm">IBAN</div>
                        <div class="font-monospace fw-600">@Model.RecipientIban</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.RecipientBankName))
                    {
                        <div class="text-end">
                            <div class="text-muted-sm">Bank</div>
                            <div class="fw-600">@Model.RecipientBankName</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Transfer details form -->
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-2-circle text-primary"></i>
                <span>Step 2 — Transfer Details</span>
            </div>
            <div class="card-body">

                <form asp-action="Preview" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="RecipientIban" />
                    <input type="hidden" asp-for="RecipientBankName" />

                    <!-- Source Account -->
                    <div class="form-group">
                        <label asp-for="SelectedAccountId" class="form-label">
                            <i class="bi bi-bank me-1"></i>From Account
                        </label>
                        <select asp-for="SelectedAccountId"
                                asp-items="Model.AccountSelectList"
                                class="form-select">
                            <option value="0">— Select source account —</option>
                        </select>
                        <span asp-validation-for="SelectedAccountId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Recipient Name -->
                    <div class="form-group">
                        <label asp-for="RecipientName" class="form-label">
                            <i class="bi bi-person me-1"></i>Recipient Name
                        </label>
                        <input asp-for="RecipientName"
                               class="form-control"
                               placeholder="Full name of the recipient" />
                        <span asp-validation-for="RecipientName" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Currency -->
                    <div class="form-group">
                        <label asp-for="Currency" class="form-label">
                            <i class="bi bi-cash-stack me-1"></i>Currency
                        </label>
                        <select asp-for="Currency" class="form-select">
                            <option value="">— Select currency —</option>
                            @foreach (var currency in BankingApp.Web.Models.Transfers.TransferIbanValidatedModel.SupportedCurrencies)
                            {
                                <option value="@currency">@currency</option>
                            }
                        </select>
                        <span asp-validation-for="Currency" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Amount -->
                    <div class="form-group">
                        <label asp-for="Amount" class="form-label">
                            <i class="bi bi-currency-dollar me-1"></i>Amount
                        </label>
                        <input asp-for="Amount"
                               type="number"
                               step="0.01"
                               min="0.01"
                               class="form-control"
                               placeholder="0.00" />
                        <span asp-validation-for="Amount" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Reference -->
                    <div class="form-group">
                        <label asp-for="Reference" class="form-label">
                            <i class="bi bi-chat-text me-1"></i>Reference (optional)
                        </label>
                        <input asp-for="Reference"
                               class="form-control"
                               placeholder="e.g. Invoice #123" />
                        <span asp-validation-for="Reference" class="invalid-feedback d-block"></span>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="divider"></div>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                        <a asp-action="New" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-eye me-2"></i>Preview Transfer
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
