@model BankingApp.Web.Models.Forex.ForexExchangeModel
@{
    ViewData["Title"] = "Currency Exchange";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-currency-exchange me-2 text-primary"></i>Currency Exchange</h1>
        <p class="page-subtitle">Select currencies, enter an amount, and preview the exchange rate before confirming.</p>
    </div>
    <a asp-action="History" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-clock-history me-1"></i>Exchange History
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-arrow-left-right text-primary"></i>
                <span>Exchange Details</span>
            </div>
            <div class="card-body">

                <form asp-action="Preview" method="post" id="forexForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Source Account -->
                    <div class="form-group">
                        <label asp-for="SelectedSourceAccountId" class="form-label">
                            <i class="bi bi-bank me-1"></i>From Account
                        </label>
                        <select asp-for="SelectedSourceAccountId"
                                asp-items="Model.AccountSelectList"
                                class="form-select"
                                id="sourceAccountSelect">
                            <option value="0">— Select source account —</option>
                        </select>
                        <span asp-validation-for="SelectedSourceAccountId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- From Currency -->
                    <div class="form-group">
                        <label asp-for="FromCurrency" class="form-label">
                            <i class="bi bi-cash-stack me-1"></i>From Currency
                        </label>
                        <select asp-for="FromCurrency" class="form-select" id="fromCurrencySelect">
                            <option value="">— Select currency —</option>
                            @foreach (var currency in BankingApp.Contracts.Features.Forex.ForexConstants.SupportedCurrencies)
                            {
                                <option value="@currency">@currency</option>
                            }
                        </select>
                        <span asp-validation-for="FromCurrency" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Amount -->
                    <div class="form-group">
                        <label asp-for="Amount" class="form-label">
                            <i class="bi bi-currency-dollar me-1"></i>Amount
                        </label>
                        <input asp-for="Amount"
                               type="number"
                               step="0.01"
                               min="0.01"
                               class="form-control"
                               id="amountInput"
                               placeholder="0.00" />
                        <span asp-validation-for="Amount" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="text-center my-3">
                        <i class="bi bi-arrow-down-circle-fill fs-3 text-primary"></i>
                    </div>

                    <!-- Target Account -->
                    <div class="form-group">
                        <label asp-for="SelectedTargetAccountId" class="form-label">
                            <i class="bi bi-bank me-1"></i>To Account
                        </label>
                        <select asp-for="SelectedTargetAccountId"
                                asp-items="Model.AccountSelectList"
                                class="form-select"
                                id="targetAccountSelect">
                            <option value="0">— Select target account —</option>
                        </select>
                        <span asp-validation-for="SelectedTargetAccountId" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- To Currency -->
                    <div class="form-group">
                        <label asp-for="ToCurrency" class="form-label">
                            <i class="bi bi-cash-stack me-1"></i>To Currency
                        </label>
                        <select asp-for="ToCurrency" class="form-select" id="toCurrencySelect">
                            <option value="">— Select currency —</option>
                            @foreach (var currency in BankingApp.Contracts.Features.Forex.ForexConstants.SupportedCurrencies)
                            {
                                <option value="@currency">@currency</option>
                            }
                        </select>
                        <span asp-validation-for="ToCurrency" class="invalid-feedback d-block"></span>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="divider"></div>

                    <button type="submit" class="btn btn-primary btn-full" id="previewBtn">
                        <i class="bi bi-eye me-2"></i>Preview Exchange Rate
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
