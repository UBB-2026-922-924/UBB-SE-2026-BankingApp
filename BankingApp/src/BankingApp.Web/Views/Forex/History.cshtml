@model BankingApp.Web.Models.Forex.ForexHistoryModel
@{
    ViewData["Title"] = "Exchange History";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-clock-history me-2 text-primary"></i>Exchange History</h1>
        <p class="page-subtitle">All currency exchanges made from your accounts.</p>
    </div>
    <a asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>New Exchange
    </a>
</div>

@if (!Model.HasTransactions)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-currency-exchange fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No exchanges yet</h5>
            <p class="text-muted mb-4">Your currency exchange history will appear here once you make an exchange.</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Make an Exchange
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="forexHistoryTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>From</th>
                            <th>To</th>
                            <th class="text-end">Converted</th>
                            <th class="text-end">Rate</th>
                            <th class="text-end">Commission</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Transactions)
                        {
                            <tr>
                                <td>
                                    <span class="font-monospace small fw-600">#@row.Id</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@row.SourceCurrency</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@row.TargetCurrency</span>
                                </td>
                                <td class="text-end fw-600">@row.TargetAmount.ToString("N2")</td>
                                <td class="text-end">@row.ExchangeRate.ToString("N6")</td>
                                <td class="text-end text-warning">@row.Commission.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge @row.StatusBadgeClass">@row.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="text-muted-sm">@Model.Transactions.Count exchange(s)</span>
        </div>
    </div>
}
