@{
    ViewData["Title"] = "Forbidden (403)";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 text-center py-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-shield-slash text-danger" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title fw-bold mb-3">Access Denied</h2>
                    <p class="card-text text-muted mb-4">
                        You do not have the required permissions to view this resource or perform this action.
                    </p>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-grid-1x2 me-2"></i>Return to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
