@{
    ViewData["Title"] = "Internal Server Error (500)";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 text-center py-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title fw-bold mb-3">Something Went Wrong</h2>
                    <p class="card-text text-muted mb-4">
                        We encountered an unexpected error while processing your request. Our technical team has been notified and is looking into it.
                    </p>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-grid-1x2 me-2"></i>Return to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
