@{
    ViewData["Title"] = "Unauthorized (401)";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 text-center py-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-shield-lock text-warning" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title fw-bold mb-3">Session Expired or Unauthorized</h2>
                    <p class="card-text text-muted mb-4">
                        You need to be signed in to access this page. Please log in to continue.
                    </p>
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Go to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
