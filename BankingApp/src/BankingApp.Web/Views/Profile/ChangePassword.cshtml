@model BankingApp.Web.ViewModels.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActiveProfileTab"] = "ChangePassword";
}

<div class="page-header">
    <h1 class="page-title">Profile <span class="page-title-muted">/ Settings</span></h1>
</div>

<div class="profile-layout">

    <aside class="profile-sidebar">
        @await Html.PartialAsync("_ProfileSidebar")
    </aside>

    <section class="profile-main">
        <div class="card profile-panel">
            @await Html.PartialAsync("_ProfileTabs")

            <div class="profile-tab-content">
                <!-- Section header -->
                <div class="profile-section-header">
                    <div class="profile-section-icon bg-primary-subtle text-primary">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <div>
                        <h2 class="profile-section-title">Set New Password</h2>
                        <p class="profile-section-subtitle">Choose a strong password for your account</p>
                    </div>
                </div>

                <form asp-action="ChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="profile-fields-box">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NewPassword" class="form-label">New Password</label>
                                <input asp-for="NewPassword" type="password" class="form-control"
                                       autocomplete="new-password" placeholder="Enter new password" />
                                <span asp-validation-for="NewPassword" class="invalid-feedback d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ConfirmNewPassword" class="form-label">Confirm Password</label>
                                <input asp-for="ConfirmNewPassword" type="password" class="form-control"
                                       autocomplete="new-password" placeholder="Re-enter new password" />
                                <span asp-validation-for="ConfirmNewPassword" class="invalid-feedback d-block"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Password rules hint — matches Desktop's NewPasswordDialog hints -->
                    <div class="profile-password-rules">
                        <div class="profile-password-rule">
                            <i class="bi bi-check2 me-2"></i>Minimum 8 characters
                        </div>
                        <div class="profile-password-rule">
                            <i class="bi bi-check2 me-2"></i>Mix of letters, numbers and symbols
                        </div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-sm-6">
                            <a asp-action="Security" class="btn btn-outline-secondary w-100">
                                Cancel
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-check-lg me-1"></i>Update Password
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
