@model BankingApp.Web.ViewModels.Profile.PersonalInfoViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActiveProfileTab"] = "PersonalInfo";
}

<div class="page-header">
    <h1 class="page-title">Profile <span class="page-title-muted">/ Settings</span></h1>
</div>

<div class="profile-layout">

    <!-- ═══ Left sidebar — profile card ═══ -->
    <aside class="profile-sidebar">
        @await Html.PartialAsync("_ProfileSidebar")
    </aside>

    <!-- ═══ Right panel — tabs + content ═══ -->
    <section class="profile-main">
        <div class="card profile-panel">
            @await Html.PartialAsync("_ProfileTabs")

            <div class="profile-tab-content">
                <!-- Section header -->
                <div class="profile-section-header">
                    <div class="profile-section-icon bg-primary-subtle text-primary">
                        <i class="bi bi-person"></i>
                    </div>
                    <div>
                        <h2 class="profile-section-title">Personal Information</h2>
                        <p class="profile-section-subtitle">View and update your personal details</p>
                    </div>
                </div>

                <!-- Fields -->
                <form asp-action="PersonalInfo" method="post" novalidate id="personalInfoForm">
                    @Html.AntiForgeryToken()

                    <div class="profile-fields-box">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label">Full Name</label>
                                <input asp-for="FullName" class="form-control" placeholder="Enter your full name" readonly="@(!Model.IsUnlocked)" disabled="@(!Model.IsUnlocked)" />
                                @if (Model.IsUnlocked) { <span asp-validation-for="FullName" class="invalid-feedback d-block"></span> }
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label">Email Address</label>
                                <input asp-for="Email" class="form-control profile-field-readonly" readonly disabled />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Enter your phone number" readonly="@(!Model.IsUnlocked)" disabled="@(!Model.IsUnlocked)" />
                                @if (Model.IsUnlocked) { <span asp-validation-for="PhoneNumber" class="invalid-feedback d-block"></span> }
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Address" class="form-label">Address</label>
                                <input asp-for="Address" class="form-control" placeholder="Enter your address" readonly="@(!Model.IsUnlocked)" disabled="@(!Model.IsUnlocked)" />
                                @if (Model.IsUnlocked) { <span asp-validation-for="Address" class="invalid-feedback d-block"></span> }
                            </div>
                        </div>
                    </div>

                    @if (Model.IsUnlocked)
                    {
                        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>
                    }

                    <!-- Info note -->
                    <div class="profile-info-note">
                        <i class="bi bi-info-circle me-2"></i>
                        Contact your bank to change your email address.
                    </div>

                    <!-- Buttons -->
                    <div class="row g-2 mt-2">
                        @if (Model.IsUnlocked)
                        {
                            <div class="col-sm-6">
                                <button type="submit" asp-action="CancelUpdate" class="btn btn-outline-secondary w-100" formnovalidate>
                                    Cancel Update
                                </button>
                            </div>
                            <div class="col-sm-6">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-check-lg me-1"></i>Save Changes
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#unlockModal">
                                    <i class="bi bi-unlock-fill me-1"></i>Unlock Update
                                </button>
                            </div>
                        }
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>

<!-- Unlock Modal -->
<div class="modal fade" id="unlockModal" tabindex="-1" aria-labelledby="unlockModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="unlockModalLabel">
                    <i class="bi bi-shield-lock text-danger me-2"></i>Unlock Profile
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UnlockPersonalInfo" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="modal-body pt-0">
                    <p class="text-muted small mb-3">Please verify your identity to enable editing.</p>
                    <div class="mb-3">
                        <label asp-for="UnlockPassword" class="form-label">Current Password</label>
                        <input asp-for="UnlockPassword" type="password" class="form-control" placeholder="Enter your current password" autocomplete="current-password" required />
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Verify</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
