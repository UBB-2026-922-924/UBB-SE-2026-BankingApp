@model BankingApp.Web.ViewModels.Profile.VerifyPasswordViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActiveProfileTab"] = "Security";
}

<div class="page-header">
    <h1 class="page-title">Profile <span class="page-title-muted">/ Settings</span></h1>
</div>

<div class="profile-layout">

    <aside class="profile-sidebar">
        @await Html.PartialAsync("_ProfileSidebar")
    </aside>

    <section class="profile-main">
        <div class="card profile-panel">
            @await Html.PartialAsync("_ProfileTabs")

            <div class="profile-tab-content">
                <!-- Section header -->
                <div class="profile-section-header">
                    <div class="profile-section-icon bg-danger-subtle text-danger">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <div>
                        <h2 class="profile-section-title">Security Settings</h2>
                        <p class="profile-section-subtitle">Manage your authentication and password</p>
                    </div>
                </div>

                <!-- Password settings card -->
                <div class="profile-security-card">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="profile-section-icon-sm bg-danger-subtle text-danger">
                            <i class="bi bi-key"></i>
                        </div>
                        <div>
                            <h3 class="profile-subsection-title">Password Settings</h3>
                            <p class="profile-section-subtitle mb-0">Verify your identity to change your password</p>
                        </div>
                    </div>

                    <form asp-action="Security" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control"
                                   autocomplete="current-password" placeholder="Enter your current password" />
                            <span asp-validation-for="CurrentPassword" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Security hint -->
                        <div class="profile-info-note profile-info-note-blue mb-3">
                            <i class="bi bi-shield-check me-2"></i>
                            Your identity is verified before any password changes are applied.
                        </div>

                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-shield-lock me-2"></i>Verify &amp; Continue
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
