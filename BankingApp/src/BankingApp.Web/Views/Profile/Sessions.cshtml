@model BankingApp.Web.ViewModels.Profile.SessionsViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActiveProfileTab"] = "Sessions";
}

<div class="page-header">
    <h1 class="page-title">Profile <span class="page-title-muted">/ Settings</span></h1>
</div>

<div class="profile-layout">

    <aside class="profile-sidebar">
        @await Html.PartialAsync("_ProfileSidebar")
    </aside>

    <section class="profile-main">
        <div class="card profile-panel">
            @await Html.PartialAsync("_ProfileTabs")

            <div class="profile-tab-content">
                <!-- Section header -->
                <div class="profile-section-header">
                    <div class="profile-section-icon bg-primary-subtle text-primary">
                        <i class="bi bi-laptop"></i>
                    </div>
                    <div>
                        <h2 class="profile-section-title">Active Sessions</h2>
                        <p class="profile-section-subtitle">Manage devices that are logged into your account</p>
                    </div>
                </div>

                @if (!Model.Sessions.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-shield-lock fs-1 text-muted d-block mb-2"></i>
                        <p class="text-muted">No active sessions found.</p>
                    </div>
                }
                else
                {
                    <div class="profile-sessions-list">
                        @foreach (var session in Model.Sessions)
                        {
                            var isCurrent = session.Id == Model.CurrentSessionId;
                            var confirmMessage = isCurrent
                                ? "This will sign you out of this device. Continue?"
                                : "Revoke this session?";

                            <div class="profile-session-card @(isCurrent ? "profile-session-current" : "")">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="profile-session-icon @(isCurrent ? "bg-success-subtle text-success" : "bg-primary-subtle text-primary")">
                                        <i class="bi bi-laptop"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="fw-semibold">@(session.Browser ?? session.DeviceInfo ?? "Unknown")</span>
                                            @if (isCurrent)
                                            {
                                                <span class="badge bg-success">Current</span>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            <span class="me-3"><i class="bi bi-globe me-1"></i>@(session.IpAddress ?? "—")</span>
                                            <span><i class="bi bi-clock me-1"></i>@session.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                    <form asp-action="RevokeSession" asp-route-sessionId="@session.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('@confirmMessage')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(isCurrent ? "btn-outline-danger" : "btn-outline-secondary")">
                                            <i class="bi bi-x-circle me-1"></i>Revoke
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </section>
</div>
