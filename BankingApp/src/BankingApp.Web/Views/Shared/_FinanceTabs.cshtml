@model string
@{
    string active = Model ?? string.Empty;
}
<nav class="finance-tabs mb-4">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link @(active == "savings" ? "active" : string.Empty)"
               asp-controller="Savings" asp-action="Index">
                <i class="bi bi-piggy-bank me-1"></i>Savings
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(active == "loans" ? "active" : string.Empty)"
               asp-controller="Loans" asp-action="Index">
                <i class="bi bi-cash-stack me-1"></i>Loans
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(active == "investments" ? "active" : string.Empty)"
               asp-controller="InvestmentsAndTrading" asp-action="Index">
                <i class="bi bi-graph-up-arrow me-1"></i>Investments
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(active == "statistics" ? "active" : string.Empty)"
               asp-controller="Statistics" asp-action="Index">
                <i class="bi bi-bar-chart-line me-1"></i>Statistics
            </a>
        </li>
    </ul>
</nav>
