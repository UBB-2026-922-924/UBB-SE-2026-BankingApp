@model AccountCardViewModel
<div class="card account-card h-100">
    <div class="card-body d-flex flex-column gap-2">
        <div class="d-flex justify-content-between align-items-start">
            <span class="fw-600 text-truncate">@Model.AccountName</span>
            @if (Model.IsActive)
            {
                <span class="badge bg-success ms-2">Active</span>
            }
            else
            {
                <span class="badge bg-secondary ms-2">@Model.Status</span>
            }
        </div>
        <div class="font-monospace text-muted-sm small">@Model.MaskedCardNumber</div>
        <div class="mt-auto">
            <span class="small text-muted">@Model.CardType</span>
            <div class="fw-700 fs-5 amount-credit">@Model.Balance.ToString("N2")</div>
        </div>
    </div>
</div>
