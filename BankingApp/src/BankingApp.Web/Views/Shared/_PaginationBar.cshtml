@model PaginationBarViewModel
@{
    RouteValueDictionary BuildRouteValues(int pageNumber)
    {
        RouteValueDictionary values = new(Model.AdditionalRouteValues) { ["page"] = pageNumber };
        return values;
    }
}
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mb-0">
        <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
            <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, BuildRouteValues(Model.CurrentPage - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>
        @foreach (int pageNumber in Model.VisiblePageNumbers)
        {
            <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : string.Empty)">
                <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, BuildRouteValues(pageNumber))">@pageNumber</a>
            </li>
        }
        <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
            <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, BuildRouteValues(Model.CurrentPage + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
