<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BankingApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        bool IsActive(string controller, string? action = null)
        {
            var controllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
            if (action is null) return controllerMatch;
            return controllerMatch && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        }
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark site-navbar">
            <div class="container-fluid px-4">

                <a class="navbar-brand site-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bank"></i>BankingApp
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Dashboard") ? "active" : string.Empty)"
                                       asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid-1x2 me-1"></i>Dashboard
                                    @{
                                        var notifCount = ViewData["NotificationCount"] is int n ? n : 0;
                                    }
                                    @if (notifCount > 0)
                                    {
                                        <span class="badge rounded-pill bg-danger ms-1" style="font-size:.65rem;vertical-align:middle;">
                                            @notifCount
                                        </span>
                                    }
                                </a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Accounts") ? "active" : string.Empty)"
                                   asp-controller="Accounts" asp-action="Index">
                                    <i class="bi bi-arrow-left-right me-1"></i>Transfers
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Transfers") ? "active" : string.Empty)"
                                       asp-controller="Transfers" asp-action="New">
                                    <i class="bi bi-arrow-left-right me-1"></i>Transfers
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Forex") ? "active" : string.Empty)"
                                       asp-controller="Forex" asp-action="Index">
                                    <i class="bi bi-currency-exchange me-1"></i>Currency Exchange
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("BillPayments") ? "active" : string.Empty)"
                                       asp-controller="BillPayments" asp-action="Index">
                                    <i class="bi bi-receipt me-1"></i>Bill Payments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Beneficiaries") ? "active" : string.Empty)"
                                       asp-controller="Beneficiaries" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Beneficiaries
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Cards") ? "active" : string.Empty)"
                                       asp-controller="Cards" asp-action="Index">
                                    <i class="bi bi-credit-card me-1"></i>Cards
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Transactions") ? "active" : string.Empty)"
                                   asp-controller="Transactions" asp-action="Index">
                                    <i class="bi bi-arrow-left-right me-1"></i>Transactions
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Savings") ? "active" : string.Empty)"
                                       asp-controller="Savings" asp-action="Index">
                                    <i class="bi bi-piggy-bank me-1"></i>Savings
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Loans") ? "active" : string.Empty)"
                                       asp-controller="Loans" asp-action="Index">
                                    <i class="bi bi-cash-stack me-1"></i>Loans
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("InvestmentsAndTrading") ? "active" : string.Empty)"
                                       asp-controller="InvestmentsAndTrading" asp-action="Index">
                                    <i class="bi bi-graph-up-arrow me-1"></i>Investments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Statistics") ? "active" : string.Empty)"
                                       asp-controller="Statistics" asp-action="Index">
                                    <i class="bi bi-bar-chart-line me-1"></i>Statistics
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Chat") ? "active" : string.Empty)"
                                       asp-controller="Chat" asp-action="Index">
                                    <i class="bi bi-chat-dots me-1"></i>Support
                                </a>
                            </li>

                        </ul>

                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">

                            @{
                                var displayName = User.FindFirst("name")?.Value
                                                  ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                                                  ?? User.Identity?.Name
                                                  ?? "Account";
                            }

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Profile") ? "active" : string.Empty)"
                                       asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle me-1"></i>
                                    <span class="d-none d-lg-inline">@displayName</span>
                                    <span class="d-inline d-lg-none">Profile</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm nav-logout-btn">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>

                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-2">

                            <li class="nav-item">
                                <a class="nav-link @(IsActive("Auth", "Login") ? "active" : string.Empty)"
                                       asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm nav-register-btn"
                                       asp-controller="Auth" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i>Register
                                </a>
                            </li>

                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        <div class="container-fluid px-4 py-4">
            @await Html.PartialAsync("_FlashMessage")
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer mt-auto">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center py-3">
                <span class="text-muted small">&copy; @DateTime.Now.Year BankingApp</span>
                <a asp-controller="Home" asp-action="Privacy"
                   class="text-muted small text-decoration-none footer-link">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
