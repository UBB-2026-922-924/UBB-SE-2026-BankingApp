@model BillerCardViewModel
<button type="button"
        class="list-group-item list-group-item-action saved-biller-item py-3 px-3"
        data-biller-id="@Model.BillerId"
        data-biller-ref="@Model.DefaultReference"
        title="Click to pre-fill the form">
    <div class="d-flex align-items-center gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" alt="@Model.DisplayName"
                 class="rounded" width="36" height="36"
                 style="object-fit:contain;" />
        }
        else
        {
            <div class="biller-icon-placeholder rounded d-flex align-items-center justify-content-center"
                 style="width:36px;height:36px;background:var(--ba-surface);">
                <i class="bi bi-building text-primary"></i>
            </div>
        }
        <div class="flex-grow-1 text-start overflow-hidden">
            <div class="fw-600 text-truncate small">@Model.DisplayName</div>
            <div class="text-muted-sm text-truncate">@Model.Category</div>
        </div>
        <i class="bi bi-chevron-right text-muted small"></i>
    </div>
</button>
